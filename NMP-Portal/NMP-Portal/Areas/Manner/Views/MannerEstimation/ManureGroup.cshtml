@using NMP.Commons.Enums
@using NMP.Commons.Resources
@using NMP.Commons.ViewModels
@model MannerEstimationStep11ViewModel

@{
    string title = Resource.lblMannerEstimate;
    string heading = Resource.lblWhatTypeOfOrganicMaterialWouldYouLikeUse;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";
    string backAction = (Enum.IsDefined(typeof(NMP.Commons.Enums.EarlyOrLateSownCropTypes), Model.CropTypeId) ? "IsEarlySown" : "CropType");

}
@section BeforeContent {
    <govuk-back-link asp-action="@(Model.IsCheckAnswer ? "CheckAnswer" : backAction)" asp-controller="MannerEstimation">@Resource.lblBack</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="ManureGroup" method="post" asp-controller="MannerEstimation" autocomplete="off">
            @Html.AntiForgeryToken()
            <govuk-radios asp-for="@Model.ManureGroupId">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @heading
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-hint>
                        @Resource.lblSelectOneOptionTheseOptionsComeFromAHDB
                    </govuk-radios-hint>

                    @foreach (var item in ViewBag.ManureGroupList)
                    {
                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                    }
                </govuk-radios-fieldset>
            </govuk-radios>

             <govuk-button type="submit" data-prevent-double-click="true" class="govuk-button margin-bottom-forty margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
        </form>
        <p class="govuk-body cancel-link">
            @if (!Model.IsCheckAnswer)
            {
                <a class="govuk-link" asp-action="MannerEstimationCancel" asp-controller="MannerEstimation">@Resource.lblCancel</a>
            }
            else
            {
                <a class="govuk-link" asp-action="CheckAnswer" asp-controller="MannerEstimation">@Resource.lblCancel</a>
            }
        </p>
    </div>
</div>
@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.StorageCapacityViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedStoreCapacityId)) ? Resource.lblUpdateOrganicMaterialStorage : Resource.lblAddAManureStore;
    ViewData["Title"] = $"{string.Format(Resource.WhatKindOfStorageIsStoreName, Model.StoreName)} {Resource.lblHyphen} {title}";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.StorageCapacityWizardStep.StorageTypes;
}

@section BeforeContent {
    <govuk-back-link asp-action="@((Model.IsCheckAnswer==true && !Model.IsMaterialTypeChange) ? "CheckAnswer" : "StoreName")" asp-controller="StorageCapacity">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnStorageTypes"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["ErrorOnStorageTypes"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@if (Model != null)
{
    <form asp-action="StorageTypes" asp-controller="StorageCapacity" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/StorageCapacity/_StorageCapacityWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">

                <govuk-radios class="govuk-radios" for="@Model.StorageTypeID">
                    <govuk-radios-fieldset>
                        <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                            @string.Format(Resource.WhatKindOfStorageIsStoreName,Model.StoreName)
                        </govuk-radios-fieldset-legend>
                        <govuk-radios-hint>@Resource.lblSelectOneOption</govuk-radios-hint>
                        @if (Model.MaterialStateID == (int)NMP.Commons.Enums.MaterialState.DirtyWaterStorage ||
                                            Model.MaterialStateID == (int)NMP.Commons.Enums.MaterialState.SlurryStorage)
                        {
                            @if (ViewBag.StorageTypes != null && ViewBag.StorageTypes.Count > 0)
                            {
                                foreach (var storageType in ViewBag.StorageTypes)
                                {
                                    <govuk-radios-item value="@storageType.ID">@storageType.Name</govuk-radios-item>
                                }
                            }
                        }
                        else
                        {
                            @if (ViewBag.SolidManureTypeList != null && ViewBag.SolidManureTypeList.Count > 0)
                            {
                                foreach (var solidManureType in ViewBag.SolidManureTypeList)
                                {
                                    <govuk-radios-item value="@solidManureType.ID">@solidManureType.Name</govuk-radios-item>
                                }
                            }
                        }
                    </govuk-radios-fieldset>
                </govuk-radios>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>

                <p class="govuk-body cancel-link">
                    @if (!Model.IsCheckAnswer)
                    {
                        @if (Model.IsStoreCapacityExist == true)
                        {
                            <a asp-action="ManageStorageCapacity" asp-controller="StorageCapacity" asp-route-q="@Model.EncryptedFarmID" asp-route-t="@Model.IsComingFromManageToHubPage" asp-route-isPlan="@Model.IsComingFromPlan" asp-route-u="@Model.IsRemovedRecently">
                                @Resource.lblCancel
                            </a>
                        }
                        else
                        {
                            @if (!string.IsNullOrWhiteSpace(Model.IsComingFromPlan))
                            {
                                <a asp-action="HarvestYearOverview" asp-controller="Crop" asp-route-id="@Model.EncryptedFarmID" asp-route-year="@Model.EncryptedHarvestYear">
                                    @Resource.lblCancel
                                </a>
                            }
                            else
                            {
                                <a asp-action="FarmSummary" asp-controller="Farm" asp-route-Id="@Model.EncryptedFarmID">
                                    @Resource.lblCancel
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <a asp-action="CheckAnswer" asp-controller="StorageCapacity">@Resource.lblCancel</a>
                    }
                </p>

            </div>

        </div>
    </form>
}
@using NMP.Commons.Resources
@using NMP.Commons.ViewModels
@model SnsAnalysisViewModel

@{
    ViewData["Title"] = $"{string.Format(Resource.lblTheInformationEnteredAboutThisWillBeLost, Resource.lblSoilNitrogenSupplyAnalysis.ToLower())} {Resource.lblHyphen} {Resource.AddASoilMineralNitrogenAnalysisResult}";

    var cancelViewModel = new CancelViewModel
            {
                IsCancel = Model.IsCancel,
                LableContent = string.Format(Resource.lblTheInformationEnteredAboutThisWillBeLost, Resource.lblSoilNitrogenSupplyAnalysis.ToLower())
            };
}

@section BeforeContent {
    <govuk-back-link asp-action="CheckAnswer" asp-controller="SnsAnalysis">@Resource.lblBack</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @if (TempData["Error"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["Error"]</govuk-error-summary-item>
            </govuk-error-summary>
        }
        <form asp-action="Cancel" method="post" asp-controller="SnsAnalysis" autocomplete="off">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/SnsAnalysis/_SnsAnalysisWizardHiddenFields.cshtml", Model)
            @await Html.PartialAsync("~/views/shared/_cancelconfirmation.cshtml", cancelViewModel)
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
        </form>
        <p class="govuk-body cancel-link"><a asp-action="CheckAnswer" asp-controller="SnsAnalysis">@Resource.lblCancel</a></p>
    </div>
</div>
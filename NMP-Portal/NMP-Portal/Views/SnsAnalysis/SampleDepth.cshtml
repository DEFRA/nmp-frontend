@using NMP.Commons.Resources
@using NMP.Commons.ViewModels
@model SnsAnalysisViewModel

@{
    ViewData["Title"] = $"{string.Format(Resource.lblAddSoilMineralNitrogen, Model.FieldName)} {Resource.lblHyphen} {Resource.AddASoilMineralNitrogenAnalysisResult}";
    var backAction = Model.IsCheckAnswer ? "CheckAnswer" : "SoilSampleDate";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.SnsAnalysisWizardSteps.SampleDepth;
}

@section BeforeContent {
    <govuk-back-link asp-action=@backAction asp-controller="SnsAnalysis">@Resource.lblBack</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @if (TempData["SoilMineralNitrogenError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item>@TempData["SoilMineralNitrogenError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }

        <form asp-action="SampleDepth" method="post" asp-controller="SnsAnalysis" autocomplete="off">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/SnsAnalysis/_SnsAnalysisWizardHiddenFields.cshtml", Model)
            <legand class="govuk-fieldset__legend govuk-fieldset__legend--l">
                <h1 class="govuk-fieldset__heading">@string.Format(Resource.lblAddSoilMineralNitrogen, Model.FieldName)</h1>
            </legand>
            <govuk-input name="SampleDepth" asp-for=@Model.SampleDepth inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                <govuk-input-label is-page-heading="true">@Resource.lblWhatWasTheSampleDepth</govuk-input-label>
            </govuk-input>
            <govuk-input name="SoilMineralNitrogen" asp-for=@Model.SoilMineralNitrogen inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                <govuk-input-label is-page-heading="true">@Resource.lblWhatWasTheSoilMineralNitrogen</govuk-input-label>
            </govuk-input>
            <govuk-button type="submit" data-prevent-double-click="true" class="govuk-button margin-bottom-forty margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
        </form>
        <p class="govuk-body cancel-link">
            @if (!Model.IsCheckAnswer)
            {
                <a class="govuk-link" asp-action="SnsAnalysisCancel" asp-controller="SnsAnalysis" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedFieldId" asp-route-s="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
            }
            else
            {
                <a class="govuk-link" asp-action="CheckAnswer" asp-controller="SnsAnalysis">@Resource.lblCancel</a>
            }
        </p>
    </div>
</div>
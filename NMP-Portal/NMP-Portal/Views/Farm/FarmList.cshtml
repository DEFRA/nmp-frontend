@using NMP.Commons.Resources;
@using NMP.Commons.ViewModels;
@using Newtonsoft.Json
@model FarmsViewModel
@{
    ViewData["Title"] = Resource.lblYourFarms;
    int enrolmentCount = Convert.ToInt32(User.Claims.FirstOrDefault(c => c.Type == "enrolmentCount")?.Value);
     
    int organisationCount = ((SelectList)ViewBag.Organisations).Count();

}

@if (TempData["Error"] != null)
{
    <govuk-error-summary>
        <govuk-error-summary-item href="#">@TempData["Error"]</govuk-error-summary-item>
    </govuk-error-summary>
}
else
{
    <div class="govuk-grid-row">
        <div id="all-plans-table" class="govuk-grid-column-two-thirds-from-desktop">

            @if (ViewBag.Success != null && ViewBag.Success == "true")
            {
                <govuk-notification-banner type="NotificationBannerType.Success">
                    <div class="">
                        <h3 class="govuk-notification-banner__heading"> @string.Format(Resource.lblYouHaveRemoved, ViewBag.FarmName)</h3>
                    </div>
                </govuk-notification-banner>
            }

            <h1 class="govuk-heading-l">
                @Resource.lblYourFarms
            </h1>
            @if (Model != null && Model.Farms.Count > 0)
            {
                @foreach (var farm in Model.Farms)
                {
                    <p class="govuk-body">
                        <a asp-action="FarmSummary" asp-controller="Farm" asp-route-id="@farm.EncryptedFarmId">@farm.Name</a>
                    </p>
                }
                <hr class="seperator_five" />
                <div>
                    <p class="govuk-heading-m">
                        @Resource.lblAddANewFarm
                    </p>
                    <p class="govuk-body">
                        <a class="govuk-link" asp-action="Name" asp-controller="Farm">@Resource.lblAddAFarm</a>
                    </p>
                    @if (enrolmentCount > 1 && organisationCount > 0)
                    {
                        <p class="govuk-body">
                            <a class="govuk-link" asp-action="SelectOrganisation" asp-controller="Farm">@Resource.TransferFarmFromAnotherCompany</a>
                        </p>
                    }
                </div>
            }
            else
            {
                <p class="govuk-body">@Resource.lblYouHaveNotAddedAnyFarms</p>
                <govuk-button-link asp-action="Name" asp-controller="Farm">@Resource.lblAddAFarm</govuk-button-link>
                @if (enrolmentCount > 1 && organisationCount > 0)
                {
                    <govuk-button-link asp-action="SelectOrganisation" asp-controller="Farm">@Resource.TransferFarmFromAnotherCompany</govuk-button-link>
                }
            }
        </div>
    </div>
}

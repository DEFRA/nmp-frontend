@using NMP.Commons.Resources
@using NMP.Commons.ServiceResponses
@model NMP.Commons.ViewModels.PlanViewModel
@{
    
    var EnterDifferentFiguresForEachField = (int)NMP.Commons.Enums.YieldQuestion.EnterDifferentFiguresForEachField;
    var EnterASingleFigureForAllTheseFields = (int)NMP.Commons.Enums.YieldQuestion.EnterASingleFigureForAllTheseFields;
    var pageHeading = "";
    if (Model.Crops != null && Model.Crops.Count > 1 && Model.GrassGrowthClassDistinctCount == 1)
    {
        pageHeading = Resource.lblAnnualDryMatterYield;
    }
    @if (Model.Crops != null && Model.Crops.Count == 1 || Model.GrassGrowthClassDistinctCount > 1)
    {
        pageHeading = string.Format(Resource.lblTargetDryMatterYieldForField, Model.FieldName);
    }
    string title = (!string.IsNullOrEmpty(Model.EncryptedIsCropUpdate)) ? Resource.lblUpdatePlan : Resource.lblCreatePlan;
    ViewData["Title"] = $"{pageHeading} {Resource.lblHyphen} {title}";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.CropWizardSteps.GrassGrowthClass;
}

@section BeforeContent {
    <govuk-back-link asp-action=@(Model.IsCheckAnswer && (!Model.IsAnyChangeInField) && (!Model.IsCropGroupChange) && (!Model.IsCurrentSwardChange) ? "CheckAnswer" : "GrassGrowthClass") asp-controller="Crop" asp-route-q="@Model.GrassGrowthClassEncryptedCounter">@Resource.lblBack</govuk-back-link>
}
<form asp-action="GrassGrowthClass" asp-controller="Crop" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @if (TempData["CropInfoOneError"] != null)
    {
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["CropInfoOneError"]</govuk-error-summary-item>
                </govuk-error-summary>
            </div>
        </div>
    }
    @await Html.PartialAsync("~/Views/Crop/_CropWizardHiddenFields.cshtml", Model)
    @if (Model.Crops != null && Model.Crops.Count > 0)
    {
        @for (int i = 0; i < Model.Crops.Count; i++)
        {
            @if (i == Model.GrassGrowthClassCounter)
            {
                <div class="govuk-grid-row">
                    <div class="govuk-grid-column-two-thirds">
                        
                            @if (Model.Crops.Count > 1 && Model.GrassGrowthClassDistinctCount == 1)
                            {
                                <h1 class="govuk-heading-l">
                                    @Resource.lblAnnualDryMatterYield
                                </h1>                               
                            }
                            @if (Model.Crops.Count == 1 || Model.GrassGrowthClassDistinctCount > 1)
                            {
                                <h1 class="govuk-heading-l">
                                    @string.Format(Resource.lblTargetDryMatterYieldForField, Model.FieldName)
                                </h1>                               
                            }
                        <p class="govuk-body">@Resource.lblWeUseTheTargetAnnaulDryMatterYieldToGiveNitrogenRecommendationsForGrass <a class="govuk-link" target="_blank"  href="https://ahdb.org.uk/knowledge-library/methods-for-measuring-forage-yield">@Resource.msgViewAhdbGuidence</a>.</p>

                            <h2 class="govuk-heading-m">@Resource.lblGrassGrowthClass</h2>
                            <div class="text_group">
                                @if (Model.Crops.Count > 1 && Model.GrassGrowthClassDistinctCount == 1)
                                {
                                    <p class="govuk-body">@Resource.lblBasedOnYourDataTheGrassGrowthClassForTheseField</p>
                                }
                                @if (Model.Crops.Count == 1 || Model.GrassGrowthClassDistinctCount > 1)
                                {
                                    <p class="govuk-body">@string.Format(Resource.lblBasedOnYourDataTheGrassGrowthClassForXField, Model.FieldName)</p>
                                }
                                @if (ViewBag.GrassGrowthClass != null)
                                {
                                    <p class="govuk-body strong"><b>@ViewBag.GrassGrowthClass</b></p>
                                }
                            </div>
                            @if (Model.Crops.Count == 1 || Model.GrassGrowthClassDistinctCount > 1)
                            {
                                <p class="govuk-body">@Resource.lblThisGivesTheFollowingRangeForAnnualDryMatterYield</p>                                                            
                                <govuk-radios for="@Model.Crops[i].Yield">
                                    <govuk-radios-fieldset>
                                        <govuk-radios-fieldset-legend is-page-heading="false">
                                        @string.Format(Resource.lblWhatIsTheTotalTargetDryMatterYieldForField, Model.FieldName, Model.Crops[0].Year)
                                        </govuk-radios-fieldset-legend>
                                        
                                        @if (ViewBag.YieldRanges != null)
                                        {
                                            @foreach (var yieldRanges in ViewBag.YieldRanges)
                                            {
                                                var modelYieldInt = (int)Math.Floor(Convert.ToDecimal(Model.Crops[i].Yield));
                                                bool isSelected = modelYieldInt == yieldRanges.YieldId;

                                                <govuk-radios-item value="@yieldRanges.YieldId" checked="@(isSelected)">
                                                    @(string.Concat(yieldRanges.YieldId.ToString(), " ", Resource.lblTonnesPerHectare))
                                                </govuk-radios-item>
                                            }
                                        }
                                    </govuk-radios-fieldset>
                                </govuk-radios>
                            }
                            @if (Model.Crops.Count > 1 && Model.GrassGrowthClassDistinctCount == 1)
                            {
                                <p class="govuk-body">@Resource.lblThisGrowthClassGivesARangeForAnnualDryMatterYieldOf</p>
                                @if (ViewBag.YieldMin != null && ViewBag.YieldMax != null)
                                {
                                    <p class="govuk-body"><strong>@string.Format(Resource.lblDryMatterYieldRangeTonnesPerHectare, ViewBag.YieldMin.YieldId, ViewBag.YieldMax.YieldId)</strong></p>
                                }

                                <govuk-radios for="@Model.GrassGrowthClassQuestion">
                                    <govuk-radios-fieldset>
                                        <govuk-radios-fieldset-legend is-page-heading="false">
                                            @Resource.lblDoYouWantToEnterTheSameTargetYieldForTheseFields
                                        </govuk-radios-fieldset-legend>
                                        <govuk-radios-item value="@EnterASingleFigureForAllTheseFields">@Resource.lblYesEnterTheSameTargetYieldForTheseFields</govuk-radios-item>
                                        <govuk-radios-item value="@EnterDifferentFiguresForEachField">@Resource.lblNoEnterADifferentTargetYieldForEachFields</govuk-radios-item>
                                    </govuk-radios-fieldset>
                                </govuk-radios>
                                <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.Crops[i].Yield" value="@Model.Crops[i].Yield"/>
                            }                        
                    </div>
                </div>
            }
            else
            {
                <div hidden="hidden">
                    <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.Crops[i].Yield" value="@Model.Crops[i].Yield"/>
                </div>
            }
        }
    }
    <govuk-button type="submit" class="margin-bottom-forty">
        @Resource.lblContinue
    </govuk-button>

    <p class="govuk-body cancel-link">
        @if (!Model.IsCheckAnswer)
        {
            <a asp-action="CreateCropPlanCancel" asp-controller="Crop" asp-route-q="@Model.EncryptedFarmId">@Resource.lblCancel</a>
        }
        else
        {
            <a asp-action="CheckAnswer" asp-controller="Crop">@Resource.lblCancel</a>
        }
    </p>
</form>
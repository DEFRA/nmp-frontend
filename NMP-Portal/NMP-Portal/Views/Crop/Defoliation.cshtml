@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.PlanViewModel
@{

    var bachAction = (Model.SowingDateQuestion == (int)NMP.Commons.Enums.SowingDateQuestion.NoIWillEnterTheDateLater) ? "SowingDateQuestion" :
     "SwardType";
    int OtherGroupId = (int)NMP.Commons.Enums.CropGroup.Other;
    int potentialCutId = 0;

    var pageHeading = "";
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazedOnly)
    {
        pageHeading = string.Format(Resource.lblHowManyGrazingsWillYouHaveInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForSilageOnly)
    {
        pageHeading = string.Format(Resource.lblHowManyCutsWillYouHaveInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForHayOnly)
    {
        pageHeading = string.Format(Resource.lblHowManyCutsWillYouHaveInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazingAndSilage)
    {
        pageHeading = string.Format(Resource.lblHowManyCutsAndGrazingsWillYouHaveInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazingAndHay)
    {
        pageHeading = string.Format(Resource.lblHowManyCutsAndGrazingsWillYouHaveInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }

    string title = (!string.IsNullOrEmpty(Model.EncryptedIsCropUpdate)) ? Resource.lblUpdatePlan : Resource.lblCreatePlan;
    ViewData["Title"] = $"{pageHeading} {Resource.lblHyphen} {title}";
    
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.CropWizardSteps.Defoliation;
}

@section BeforeContent {
    <govuk-back-link asp-action=@(Model.IsCheckAnswer && (!Model.IsAnyChangeInField) && (!Model.IsCropGroupChange) && (!Model.IsCurrentSwardChange) ? "CheckAnswer" : "GrassManagement") asp-controller="Crop" asp-route-q="@Model.SowingDateEncryptedCounter">@Resource.lblBack</govuk-back-link>
}
<form asp-action="Defoliation" asp-controller="Crop" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @if (TempData["DefoliationError"] != null)
    {
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["DefoliationError"]</govuk-error-summary-item>
                </govuk-error-summary>
            </div>
        </div>
    }
    @await Html.PartialAsync("~/Views/Crop/_CropWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">

            <govuk-radios for="@Model.PotentialCut">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @pageHeading
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-hint>@string.Format(Resource.lblTheseOptionsComeFromRB209, Resource.lblOptions)</govuk-radios-hint>
                    @if (ViewBag.PotentialCuts != null)
                    {
                        @foreach (var potentialCut in ViewBag.PotentialCuts)
                        {
                            <govuk-radios-item value="@(potentialCut.PotentialCutId)">@potentialCut.PotentialCutText</govuk-radios-item>
                        }
                    }

                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>

            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateCropPlanCancel" asp-controller="Crop" asp-route-q="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="Crop">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
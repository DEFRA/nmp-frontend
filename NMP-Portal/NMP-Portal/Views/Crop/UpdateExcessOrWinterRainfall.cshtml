@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.PlanViewModel
@{
    string title = Resource.lblUpdateExcessWinterRainfall;
    ViewData["Title"] = $"{string.Format(Resource.lblRainfallCategoryForFarmName, Model.FarmName)} {Resource.lblHyphen} {title}";
    int previousYear = Model.Year.Value - 1;
}

@section BeforeContent {
    <govuk-back-link asp-action="HarvestYearOverview" asp-controller="Crop" asp-route-Id="@Model.EncryptedFarmId" asp-route-year="@Model.EncryptedHarvestYear">@Resource.lblBack</govuk-back-link>
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @if (TempData["UpdateExcessOrWinterRainfallError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["UpdateExcessOrWinterRainfallError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }
        <h1 class="govuk-heading-l">
            @string.Format(Resource.lblRainfallCategoryForFarmName, Model.FarmName)
        </h1>


        <table class="govuk-table">
            <thead class="govuk-table__head">
            </thead>
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <th scope="row" class="govuk-table__header">@Resource.lblAverageAnnualRainfall</th>
                    <td class="govuk-table__cell">
                        @(Model.AnnualRainfall != null ? string.Format(Resource.lblRainfallMM, Model.AnnualRainfall) : Resource.lblNotEntered)
                </tr>
                <tr class="govuk-table__row">
                    <th scope="row" class="govuk-table__header">@(Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland ? string.Format(Resource.lblWinterRainfall1OctTo1March, previousYear, Model.Year) : Resource.lblExcessWinterRainfall)</th>
                    <td class="govuk-table__cell">
                        @if (Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland)
                        {
                            @(!string.IsNullOrWhiteSpace(Model.WinterRainfallName) ? Model.WinterRainfallName : Resource.lblNotEntered)
                        }
                        else
                        {
                            @(!string.IsNullOrWhiteSpace(Model.ExcessWinterRainfallName) ? Model.ExcessWinterRainfallName : Resource.lblNotEntered)
                        }
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="margin-bottom-forty">
            
            @if (Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland)
            {
                <a class="govuk-button add-button" asp-action="IsWinterRainfallMoreThan450" asp-controller="Crop" class="margin-bottom-forty">@Resource.lblUpdateWinterRainfall</a>
            }
            else
            {
                <a class="govuk-button add-button" asp-action="ExcessWinterRainfall" asp-controller="Crop" class="margin-bottom-forty">@Resource.lblUpdateExcessWinterRainfall</a>
            }
        </div>

        <p class="govuk-body cancel-link"><a asp-action="HarvestYearOverview" asp-controller="Crop" asp-route-Id="@Model.EncryptedFarmId" asp-route-year="@Model.EncryptedHarvestYear">@Resource.lblCancel</a></p>


    </div>
</div>
﻿@using NMP.Commons.Resources
@using System.Globalization
@model NMP.Commons.ViewModels.PlanViewModel
@{

    var heading= "";
    if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
    {
        heading = Resource.lblCheckYourAnswers;
    }
    else
    {
        heading = string.Format(Resource.lblUpdateCropGroupNameForHarvestYear, Model.CropGroupName, Model.Year);
    }

    string title = (!string.IsNullOrEmpty(Model.EncryptedIsCropUpdate)) ? Resource.lblUpdatePlan : Resource.lblCreatePlan;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";

    int PotatoGroupId = (int)NMP.Commons.Enums.CropGroup.Potatoes;
    int OtherGroupId = (int)NMP.Commons.Enums.CropGroup.Other;
    int CerealsGroupId = (int)NMP.Commons.Enums.CropGroup.Cereals;
    var yieldQuestion = "";
    var sowingDateQuestion = "";
    string backActionForYield;

    if (Model.Crops.Count > 1)
    {
        backActionForYield = "Yield";
    }
    else if (Model.SowingDateQuestion != (int)NMP.Commons.Enums.SowingDateQuestion.NoIWillEnterTheDateLater)
    {
        backActionForYield = "SowingDate";
    }
    else
    {
        backActionForYield = "SowingDateQuestion";
    }
    var backActionForYieldQuestion = (Model.SowingDateQuestion == (int)NMP.Commons.Enums.SowingDateQuestion.NoIWillEnterTheDateLater) ? "SowingDateQuestion" :
     "SowingDate";
    switch (Model.SowingDateQuestion)
    {
        case (int)NMP.Commons.Enums.SowingDateQuestion.NoIWillEnterTheDateLater:
            sowingDateQuestion = Resource.lblNoIWillEnterTheDateLater;
            break;
        case (int)NMP.Commons.Enums.SowingDateQuestion.YesIHaveASingleDateForAllTheseFields:
            sowingDateQuestion = Resource.lblYesIHaveASingleDateForAllTheseFields;
            break;
        case (int)NMP.Commons.Enums.SowingDateQuestion.YesIHaveDifferentDatesForEachOfTheseFields:
            sowingDateQuestion = Resource.lblYesIHaveDifferentDatesForEachOfTheseFields;
            break;
    }
    switch (Model.YieldQuestion)
    {
        case (int)NMP.Commons.Enums.YieldQuestion.UseTheStandardFigureForAllTheseFields:
            yieldQuestion = Model.Crops.Count > 1 ? string.Format(Resource.lblUseTheStandardFigure, ViewBag.DefaultYield??0) : string.Format(Resource.lblUseTheStandardFigureForThisField, ViewBag.DefaultYield??0);
            break;
        case (int)NMP.Commons.Enums.YieldQuestion.EnterASingleFigureForAllTheseFields:
            if (Model.Crops.Count == 1 && (ViewBag.DefaultYield == null||(ViewBag.DefaultYield!= null&&ViewBag.DefaultYield>0)))
            {
                yieldQuestion = Resource.lblEnterAFigure;
                if(ViewBag.DefaultYield==null)
                {
                    yieldQuestion = Resource.lblYes;    
                }
            }
            else
            {
                yieldQuestion = Resource.lblEnterASingleFigureForAllTheseFields;
            }

            break;
        case (int)NMP.Commons.Enums.YieldQuestion.EnterDifferentFiguresForEachField:
            yieldQuestion = Resource.lblEnterDifferentFiguresForEachField;
            break;
        case (int)NMP.Commons.Enums.YieldQuestion.NoDoNotEnterAYield:
            yieldQuestion =(Model.Crops.Count>1? Resource.lblNoDoNotEnterAYield:Resource.lblNo);
            break;

    }

    bool firstCropOnly = Model.Crops.All(crop => crop.CropOrder == 1);
    bool secondCropOnly = Model.Crops.All(crop => crop.CropOrder == 2);
    bool firstAndSecondCrop = Model.Crops.Any(crop => crop.CropOrder == 1) && Model.Crops.Any(crop => crop.CropOrder == 2);

    var currentSward = (Model.CurrentSward == (int)NMP.Commons.Enums.CurrentSward.NewSward ? Resource.lblNewSwards : Resource.lblExistingSwards);

    var potentialCutName = "";
    if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.One)
    {
        potentialCutName = Resource.lblOne;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Two)
    {
        potentialCutName = Resource.lblTwo;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Three)
    {
        potentialCutName = Resource.lblThree;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Four)
    {
        potentialCutName = Resource.lblFour;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Five)
    {
        potentialCutName = Resource.lblFive;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Six)
    {
        potentialCutName = Resource.lblSix;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Seven)
    {
        potentialCutName = Resource.lblSeven;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Eight)
    {
        potentialCutName = Resource.lblEight;
    }
    else if (Model.PotentialCut == (int)NMP.Commons.Enums.PotentialCut.Nine)
    {
        potentialCutName = Resource.lblNine;
    }



    //check answer heading

    var potentialCutText = "";
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazedOnly)
    {
        potentialCutText = string.Format(Resource.lblHowManyGrazingsWillYouHaveInTheseFields,
            (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForSilageOnly)
    {
        potentialCutText = string.Format(Resource.lblHowManyCutsWillYouHaveInTheseFields,
            (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForHayOnly)
    {
        potentialCutText = string.Format(Resource.lblHowManyCutsWillYouHaveInTheseFields,
            (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    else 
    {
        potentialCutText = string.Format(Resource.lblHowManyCutsAndGrazingsWillYouHaveInTheseFields,
            (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }

    var defoliationSequenceText = "";
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazedOnly)
    {
        defoliationSequenceText = Resource.lblWhatIsTheGrazingOrderInTheseFields;
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForSilageOnly)
    {
        defoliationSequenceText = string.Format(Resource.lblWhatIsTheCutOrderInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.CutForHayOnly)
    {
        defoliationSequenceText = string.Format(Resource.lblWhatIsTheCutOrderInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazingAndSilage)
    {
        defoliationSequenceText = string.Format(Resource.lblWhatIsTheCutAndGrazingOrderInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }
    if (Model.SwardManagementId == (int)NMP.Commons.Enums.SwardManagement.GrazingAndHay)
    {
        defoliationSequenceText = string.Format(Resource.lblWhatIsTheCutAndGrazingOrderInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields));
    }

    var isGrass = Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Grass;
    var isOther = Model.CropGroupId == OtherGroupId;
    var isPotato = Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Potatoes;
    var hasMultipleCrops = Model.Crops.Count > 1;
    var isSingleDateForAll =  Model.SowingDateQuestion == (int)NMP.Commons.Enums.SowingDateQuestion.YesIHaveASingleDateForAllTheseFields;

    string cropName =  isOther ? Model.OtherCropName : isPotato ? Model.Variety : Model.CropType;

    
    string yieldQuestionText;

    if (ViewBag.DefaultYield != null && ViewBag.DefaultYield > 0)
    {
        yieldQuestionText = string.Format(Model.Crops.Count > 1 ? Resource.lblHowDoYouWantToEnterTheExpectedYieldForInTheseFields : Resource.lblYieldQuestionForSingleField, cropName);
    }
    else
    {
        if (Model.Crops.Count > 1)
        {
            yieldQuestionText = string.Format(Resource.lblDoYouWantToEnterTheExpectedYieldInTheseFields, cropName);
        }
        else
        {
            yieldQuestionText = string.Format(Resource.lblDoYouWantToEnterTheExpectedYieldInFieldName, cropName, Model.FieldName);
        }
    }

}

@section BeforeContent {

    @*  @if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
    { *@
    <govuk-back-link asp-action=@(ViewBag.IsDataChange==true? "Cancel" : "BackCheckAnswer") asp-controller="Crop" asp-route-q="@(Model.CropGroupId==(int)NMP.Commons.Enums.CropGroup.Grass ? Model.GrassGrowthClassEncryptedCounter: Model.YieldEncryptedCounter)">@Resource.lblBack</govuk-back-link>
    @* }
    else
    {
        <govuk-back-link asp-action="HarvestYearOverview" asp-controller="Crop" asp-route-id="@Model.EncryptedFarmId" asp-route-year="@Model.EncryptedHarvestYear">@Resource.lblBack</govuk-back-link>
    } *@
}


<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
        <form class="form-with-overlay" asp-action=@(string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate)?"CheckAnswer":"UpdateCrop") asp-controller="Crop" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            @if (TempData["ErrorCreatePlan"] != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["ErrorCreatePlan"]</govuk-error-summary-item>
                </govuk-error-summary>
            }
            @if(ViewData["ModelStateErrors"]!=null)
            {
                     <govuk-error-summary>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                 <govuk-error-summary-item href="#">@error.ErrorMessage</govuk-error-summary-item>                
                                }
                </govuk-error-summary>
            }


          
            @await Html.PartialAsync("~/Views/Crop/_CropWizardHiddenFields.cshtml", Model)
            @if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
            {
                <h1 class="govuk-heading-l">
                    @Resource.lblCheckYourAnswers
                </h1>
            }
            else
            {
                <h1 class="govuk-heading-l">
                        @string.Format(Resource.lblUpdateTheCropForField,(Model.IsComingFromRecommendation.HasValue && Model.IsComingFromRecommendation.Value)? Model.CropType:Model.CropGroupName, Model.FieldName)
                    
                </h1>

                <govuk-inset-text>
                    <p class="govuk-body">
                        @if (Model.IsComingFromRecommendation.HasValue && Model.IsComingFromRecommendation.Value)
                        {
                            @string.Format(Resource.lblUpdateCropGroupNameContentForSingleField, Model.FieldName) <a asp-action="CheckAnswer" asp-controller="Crop" asp-route-q="@ViewBag.EncryptedCropTypeId" asp-route-r="@ViewBag.EncryptedCropGroupName" asp-route-t="@Model.EncryptedHarvestYear" asp-route-u="@Model.EncryptedFarmId">@Resource.lblUpdateThisCropGroup</a>

                        }
                        else
                        {
                            @Resource.lblUpdateCropGroupNameContent1 <a asp-action="HarvestYearOverview" asp-controller="Crop" asp-route-id="@Model.EncryptedFarmId" asp-route-year="@Model.EncryptedHarvestYear">@string.Format(Resource.lblViewTheYearCropPlan, Model.Year)</a>

                        }.
                    </p>
                </govuk-inset-text>
            }
            
                <govuk-summary-list>
                    @if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
                    {
                        <govuk-summary-list-row>
                            <govuk-summary-list-row-key>
                                @Resource.lblHarvestYears
                            </govuk-summary-list-row-key>
                            <govuk-summary-list-row-value>
                                @Model.Year
                            </govuk-summary-list-row-value>
                            @* @if (Model.IsPlanRecord.HasValue && (!Model.IsPlanRecord.Value))
                        {
                        <govuk-summary-list-row-actions>
                        <govuk-summary-list-row-action class="@(Model.IsAddAnotherCrop? "disabled": "")" asp-action="HarvestYearForPlan" asp-controller="Crop">@Resource.lblChange</govuk-summary-list-row-action>
                        </govuk-summary-list-row-actions>
                        } *@
                        </govuk-summary-list-row>
                    }

                    <govuk-summary-list-row>
                        <govuk-summary-list-row-key>
                            @Resource.lblCropGroup
                        </govuk-summary-list-row-key>
                        <govuk-summary-list-row-value>
                            @Model.CropGroup
                        </govuk-summary-list-row-value>
                        <govuk-summary-list-row-actions>
                            <govuk-summary-list-row-action asp-action="CropGroups" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @Resource.lblCropGroup</span></govuk-summary-list-row-action>
                        </govuk-summary-list-row-actions>
                    </govuk-summary-list-row>
                    
                    @if(Model.CropGroupId != (int)NMP.Commons.Enums.CropGroup.Grass)
                    {
                        string? cropName=null;
                        if (!Model.CropTypeID.HasValue)
                        {
                            cropName = Resource.lblNotSet;
                        }
                        else if (Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Other)
                        {
                            cropName = Model.OtherCropName;
                        }
                        else
                        {
                            cropName = Model.CropType;
                        }
                        <govuk-summary-list-row class=@((!Model.CropTypeID.HasValue)?"govuk-error-message":"")>
                        <govuk-summary-list-row-key>
                            @Resource.lblWhatIsTheCropType
                        </govuk-summary-list-row-key>
                        <govuk-summary-list-row-value>
                            @cropName
                        </govuk-summary-list-row-value>
                        <govuk-summary-list-row-actions>

                            <govuk-summary-list-row-action asp-action="CropTypes" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @Resource.lblWhatIsTheCropType</span></govuk-summary-list-row-action>

                        </govuk-summary-list-row-actions>
                    </govuk-summary-list-row>
                    }
                    
                    @if (Model.IsComingFromRecommendation == null)
                    {
                            <govuk-summary-list-row class=@(((Model.Crops?.Count ?? 0) == 0)?"govuk-error-message":"")>
                                <govuk-summary-list-row-key>
                                @string.Format(Resource.lblWhichFieldsWouldYouLikeToPlanFor, Model.CropGroupId == OtherGroupId ? Model.OtherCropName :  Model.CropType)
                            </govuk-summary-list-row-key>
                            <govuk-summary-list-row-value>
                                @if (firstCropOnly)
                                {
                                    @foreach (var crop in Model.Crops)
                                    {
                                        @crop.FieldName <br />
                                    }
                                }
                                @if (secondCropOnly)
                                {
                                    @foreach (var crop in Model.Crops)
                                    {
                                        @crop.FieldName <br />
                                    }
                                }
                                @if (firstAndSecondCrop)
                                {
                                    <b>@Resource.lblThisWillBeTheFirstCropInTheseFields</b>
                                    <br />
                                    @foreach (var crop in Model.Crops)
                                    {
                                        if (crop.CropOrder == 1)
                                        {
                                            @crop.FieldName <br />
                                        }
                                    }
                                    <br />

                                    <b>@Resource.lblThisWillBeTheSecondCropInTheseFields</b>
                                    <br />
                                    @foreach (var crop in Model.Crops)
                                    {
                                        if (crop.CropOrder == 2)
                                        {
                                            @crop.FieldName <br />
                                        }
                                    }
                                }

                            </govuk-summary-list-row-value>
                            <govuk-summary-list-row-actions>
                                @if (!(!string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate) && (ViewBag.IsFieldChange != null && ViewBag.IsFieldChange)))
                                {
                                    <govuk-summary-list-row-action class="@(ViewBag.FieldOptions != null && ViewBag.FieldOptions.Count==1? "disabled": "")" asp-action="CropFields" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @string.Format(Resource.lblWhichFieldsWouldYouLikeToPlanFor, Model.CropGroupId == OtherGroupId ? Model.OtherCropName :  Model.CropType)</span></govuk-summary-list-row-action>
                                }
                            </govuk-summary-list-row-actions>
                        </govuk-summary-list-row>

                        <govuk-summary-list-row>
                            <govuk-summary-list-row-key>
                                @Resource.lblWhatWouldYouLikeToCallThisCropGroup
                            </govuk-summary-list-row-key>
                            <govuk-summary-list-row-value>
                                @(Model.CropGroupName == null ? Resource.lblNotEntered : Model.CropGroupName)
                            </govuk-summary-list-row-value>
                            <govuk-summary-list-row-actions>
                                <govuk-summary-list-row-action asp-action="CropGroupName" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @Resource.lblWhatWouldYouLikeToCallThisCropGroup</span></govuk-summary-list-row-action>
                            </govuk-summary-list-row-actions>
                        </govuk-summary-list-row>
                    }

                    @if (Model.CropGroupId != (int)NMP.Commons.Enums.CropGroup.Grass)
                    {
                        @* @if (Model.CropGroupId != (int)NMP.Commons.Enums.CropGroup.Potatoes)
                        { *@
                            <govuk-summary-list-row>
                                <govuk-summary-list-row-key>
                                    @Resource.lblVarietyNameForCheckAnswer
                                </govuk-summary-list-row-key>
                                <govuk-summary-list-row-value>
                                    @(string.IsNullOrWhiteSpace(Model.Variety) ? Resource.lblNotEntered : Model.Variety)
                                </govuk-summary-list-row-value>
                                <govuk-summary-list-row-actions>
                                    <govuk-summary-list-row-action asp-action="VarietyName" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @Resource.lblVarietyNameForCheckAnswer</span></govuk-summary-list-row-action>
                                </govuk-summary-list-row-actions>
                            </govuk-summary-list-row>
                        @* }
                        else
                        { 
                            <govuk-summary-list-row class=@((string.IsNullOrWhiteSpace(Model.Variety))?"govuk-error-message":"")>
                                <govuk-summary-list-row-key>
                                    @Resource.lblVarietyNameForCheckAnswer
                                </govuk-summary-list-row-key>
                                <govuk-summary-list-row-value>
                                    @(string.IsNullOrWhiteSpace(Model.Variety) ? Resource.lblNotSet : Model.Variety)
                                </govuk-summary-list-row-value>
                                <govuk-summary-list-row-actions>
                                    <govuk-summary-list-row-action asp-action="VarietyName" asp-controller="Crop">@Resource.lblChange</govuk-summary-list-row-action>
                                </govuk-summary-list-row-actions>
                            </govuk-summary-list-row>
                        } *@
                    }
                    @if (Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Grass)
                    {
                        <govuk-summary-list-row class=@((!Model.CurrentSward.HasValue)?"govuk-error-message":"")>
                            <govuk-summary-list-row-key>
                                @(Model.FieldList.Count == 1 ? Resource.lblIsThisANewSwardOrExistingSward : string.Format(Resource.lblAreTheseNewSwardOrExistingSwardInTheseFields, Resource.lblTheseFields))
                            </govuk-summary-list-row-key>
                            <govuk-summary-list-row-value>
                                @(Model.CurrentSward == null ? Resource.lblNotSet : currentSward)
                            </govuk-summary-list-row-value>
                            <govuk-summary-list-row-actions>
                                <govuk-summary-list-row-action asp-action="CurrentSward" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @(Model.FieldList.Count == 1 ? Resource.lblIsThisANewSwardOrExistingSward : string.Format(Resource.lblAreTheseNewSwardOrExistingSwardInTheseFields, Resource.lblTheseFields))</span></govuk-summary-list-row-action>
                            </govuk-summary-list-row-actions>
                        </govuk-summary-list-row>


                    }
                    @if (Model.CurrentSward != (int)NMP.Commons.Enums.CurrentSward.ExistingSward)
                    {
                        @if (Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Grass)
                        {
                                <govuk-summary-list-row class=@((!Model.GrassSeason.HasValue)?"govuk-error-message":"")>
                                    <govuk-summary-list-row-key>
                                        @string.Format(Resource.lblWhenIsTheSwardInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields), Model.Year)
                                    </govuk-summary-list-row-key>
                                    <govuk-summary-list-row-value>
                                        @(Model.GrassSeason == null ? Resource.lblNotSet : Model.GrassSeasonName)
                                    </govuk-summary-list-row-value>
                                    <govuk-summary-list-row-actions>
                                        <govuk-summary-list-row-action asp-action="GrassSeason" asp-controller="Crop">@Resource.lblChange <span class="govuk-visually-hidden"> @string.Format(Resource.lblWhenIsTheSwardInTheseFields, (Model.FieldList.Count == 1 ? Model.Crops[0].FieldName : Resource.lblTheseFields), Model.Year) </span></govuk-summary-list-row-action>
                                    </govuk-summary-list-row-actions>
                                </govuk-summary-list-row>
                            
                        }

                        <govuk-summary-list-row class=@((!Model.SowingDateQuestion.HasValue)?"govuk-error-message":"")>
                            <govuk-summary-list-row-key>
                                @if(Model.CropGroupId != (int)NMP.Commons.Enums.CropGroup.Grass)
                                {
                                    @string.Format(Resource.lblDoYouHaveADateForWhenYouPlantedYour, Model.CropGroupId == OtherGroupId ? Model.OtherCropName :  Model.CropType)
                                }
                                else
                                {
                                    @string.Format(Resource.lblDoYouHaveADateForWhenYouSowedYour, Model.CropGroupId == OtherGroupId ? Model.OtherCropName :  Model.CropType)
                                }
                            </govuk-summary-list-row-key>
                            <govuk-summary-list-row-value>
                                @{
                                   string sowingDateText;
                                   
                                   if (!Model.SowingDateQuestion.HasValue)
                                   {
                                       sowingDateText = Resource.lblNotSet;
                                   }
                                   else if (Model.Crops.Count == 1 && Model.SowingDateQuestion == (int)NMP.Commons.Enums.SowingDateQuestion.YesIHaveASingleDateForAllTheseFields)
                                   {
                                       sowingDateText = Resource.lblYes;
                                   }
                                   else
                                   {
                                       sowingDateText = sowingDateQuestion;
                                   }
                                 }
                                 
                                 @sowingDateText
                               
                            </govuk-summary-list-row-value>
                            <govuk-summary-list-row-actions>
                                <govuk-summary-list-row-action asp-action="SowingDateQuestion" asp-controller="Crop">@Resource.lblChange 
                                    <span class="govuk-visually-hidden"> 
                                        @{
                                            string? cropName=string.Empty;
                                         if (Model.CropGroupId == OtherGroupId)
                                         {
                                             cropName = Model.OtherCropName;
                                         }
                                         else if (Model.CropGroupId == (int)NMP.Commons.Enums.CropGroup.Potatoes)
                                         {
                                             cropName = Model.Variety;
                                         }
                                         else
                                         {
                                             cropName = Model.CropType;
                                         }
                                        }
                                @if(Model.CropGroupId != (int)NMP.Commons.Enums.CropGroup.Grass)
                                {
                                         
                                     @string.Format(Resource.lblDoYouHaveADateForWhenYouPlantedYour, cropName)
                                }
                                else
                                {
                                    @string.Format(Resource.lblDoYouHaveADateForWhenYouSowedYour, cropName)
                                }
                                </span>
                                </govuk-summary-list-row-action>
                            </govuk-summary-list-row-actions>
                        </govuk-summary-list-row>
                        @if (Model.SowingDateQuestion == (int)NMP.Commons.Enums.SowingDateQuestion.YesIHaveASingleDateForAllTheseFields)
                        {
                            bool renderSowingDate = false;
                            @for (int i = 0; i < Model.Crops.Count; i++)
                            {
                                @if (!renderSowingDate)
                                {
                                    string questionText;

                    @if (!Model.IsComingFromRecommendation.HasValue)
                    {
                        <a asp-action="RemoveCrop" asp-controller="Crop" asp-route-q="@ViewBag.EncryptedCropTypeId" asp-route-r="@(ViewBag.EncryptedCropGroupName==null?null:ViewBag.EncryptedCropGroupName)">@Resource.lblRemoveThisCropGroup</a>
                    }
                    else
                    {
                        <a asp-action="RemoveCrop" asp-controller="Crop" asp-route-q="@Model.EncryptedCropType" asp-route-s="@Model.EncryptedFieldName" asp-route-t="@Model.EncryptedFieldId" asp-route-u="@Model.EncryptedCropOrder" asp-route-v="@Model.EncryptedFarmId" asp-route-w="@Model.EncryptedHarvestYear">@string.Format(Resource.lblRemoveCropFromFieldInYear, Model.CropType, Model.FieldName, Model.Year)</a>
                    }.
                </p>
            }
             <govuk-button type="submit" class="margin-bottom-forty" prevent-double-click="true">
                @if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
                {
                    @Resource.lblCreatePlan
                }
                else
                {
                    @((Model.IsComingFromRecommendation.HasValue && Model.IsComingFromRecommendation.Value)?Resource.lblUpdateThisField :Resource.lblUpdateThisCropGroupOnButton)
                }
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateCropPlanCancel" asp-controller="Crop" asp-route-q="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    @if (string.IsNullOrWhiteSpace(Model.EncryptedIsCropUpdate))
                    {
                        <a asp-action="Cancel" asp-controller="Crop">@Resource.lblCancel</a>
                    }
                    else
                    {
                        if(ViewBag.IsDataChange != null && ViewBag.IsDataChange==true)
                        {
                            <a asp-action="Cancel" asp-controller="Crop">@Resource.lblCancel</a>
                        }
                        else
                        {
                            <a asp-action="BackCheckAnswer" asp-controller="Crop">@Resource.lblCancel</a>
                        }
                    }
                }
            </p>
        </form>
    </div>
</div>
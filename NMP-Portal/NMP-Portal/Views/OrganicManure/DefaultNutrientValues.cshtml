@using NMP.Commons.Resources
@using NMP.Commons.ViewModels
@using System.Globalization

@model OrganicManureViewModel
@{
    var heading = "";
    if ((Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials || Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials)
                        ||
                        (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue) && Model.DefaultFarmManureValueDate.HasValue)
    {
        heading = string.Format(Resource.lblDefaultNutrientValueContentSecond, (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue && Model.DefaultFarmManureValueDate.HasValue) ? Model.ManureTypeName : Model.OtherMaterialName);
    }
    else
    {
        heading = string.Format(Resource.lblNutrientValuesFor, Model.ManureTypeName);
    }

    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";

    var DefaultNutrientValues = true;
    var NotDefaultNutrientValues = false;
    var backAction = (Model.IsCheckAnswer && Model.IsDefaultNutrientOptionChange) ? "CheckAnswer" : Model.ApplicationMethodCount > 0 ? "ApplicationMethod" : "ManureApplyingDate";

    var unit = "";
    if (Model.IsManureTypeLiquid == null)
    {
        Model.IsManureTypeLiquid = false;
    }
    if (Model.IsManureTypeLiquid != null)
    {
        unit = Model.IsManureTypeLiquid.Value ? Resource.lblValueKgPerMeterCube : Resource.lblValueKgPerTon;
    }
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.OrganicManureWizardSteps.DefaultNutrient;

}

@if (ViewBag.Error != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@ViewBag.Error</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@section BeforeContent {
    <govuk-back-link asp-action="@backAction" asp-controller="OrganicManure">@Resource.lblBack</govuk-back-link>

}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form class="form" asp-action="DefaultNutrientValues" asp-controller="OrganicManure" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
           @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)

            @if ((Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials || Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials)
                        ||
                        (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue) && Model.DefaultFarmManureValueDate.HasValue)
            {
                <h1 class="govuk-heading-l">
                    @string.Format(Resource.lblDefaultNutrientValueContentSecond, (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue && Model.DefaultFarmManureValueDate.HasValue) ? Model.ManureTypeName : Model.OtherMaterialName)
                </h1>
                <p class="govuk-body">
                    @string.Format(Resource.lblDefaultNutrientValueContentThird, Model.DefaultFarmManureValueDate?.ToLocalTime().Date.ToString("dd MMMM yyyy", CultureInfo.GetCultureInfo("en-GB")))
                </p>
            }
            else
            {
                <h1 class="govuk-heading-l">
                    @string.Format(Resource.lblNutrientValuesFor, Model.ManureTypeName)
                </h1>
                <p class="govuk-body">@Resource.lblDefaultNutrientValueContentFirst</p>
            }
            <table class="govuk-table">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                        <th id="field_name" scope="col" class="govuk-table__header">@Resource.lblNutrient</th>
                        <th scope="col" class="govuk-table__header alignRight">
                            @(Model.IsManureTypeLiquid.HasValue && Model.IsManureTypeLiquid.Value ? Resource.lblValuePerCubicMetre : Resource.lblValuePerTonne)
                        </th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblDryMatter</td>
                        <td class="govuk-table__cell alignRight">
                            @(string.Format(Resource.lblValueTotal, string.Format(Resource.lblValuePercent, Model.ManureType.DryMatter)))
                        </td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblTotalNitrogen</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.TotalN != null ? string.Format(Resource.lblValueKg, Model.ManureType.TotalN) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblAmmoniumHypenN​</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.NH4N != null ? string.Format(Resource.lblValueKg, Model.ManureType.NH4N) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblUricAcidN​</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.Uric != null ? string.Format(Resource.lblValueKg, Model.ManureType.Uric) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblNitrateHypenN​</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.NO3N != null ? string.Format(Resource.lblValueKg, Model.ManureType.NO3N) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblTotalPhosphateOnly</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.P2O5 != null ? string.Format(Resource.lblValueKg, Model.ManureType.P2O5) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblTotalPotashWithNutrient</td>
                        <td class="govuk-table__cell alignRight">@(Model.ManureType.K2O != null ? string.Format(Resource.lblValueKg, Model.ManureType.K2O) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblTotalSulphur</td>
                        <td class="govuk-table__cell alignRight">@((Model.ManureType.SO3 != null && Model.ManureType.SO3 != 0) ? string.Format(Resource.lblValueKg, Model.ManureType.SO3) : string.Empty)</td>
                    </tr>
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">@Resource.lblTotalMagnesium</td>
                        <td class="govuk-table__cell alignRight">@((Model.ManureType.MgO != null && Model.ManureType.SO3 != 0) ? string.Format(Resource.lblValueKg, Model.ManureType.MgO) : string.Empty)</td>
                    </tr>
                </tbody>
            </table>
            <govuk-radios for="@Model.DefaultNutrientValue">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="false">
                        @if ((Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials || Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials)
                                                ||
                                                (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue) && Model.DefaultFarmManureValueDate.HasValue)
                        {
                            @Resource.lblDefaultNutrientValueContentFourth

                        }
                        else
                        {
                            @Resource.lblDoYouWantToUseTheseTypicalNutrientValues
                        }
                    </govuk-radios-fieldset-legend>

                    @if (ViewBag.FarmManureApiOption != null && ViewBag.FarmManureApiOption == Resource.lblTrue)
                    {
                        <govuk-radios-item value="@Resource.lblYesUseTheseValues">@Resource.lblYesUseTheseValues</govuk-radios-item>
                        <govuk-radios-item value="@Resource.lblIwantToEnterARecentOrganicMaterialAnalysis">@Resource.lblIwantToEnterARecentOrganicMaterialAnalysis</govuk-radios-item>
                        <govuk-radios-item value="@Resource.lblYesUseTheseStandardNutrientValues">@Resource.lblUseValuesFromRB209</govuk-radios-item>
                    }
                    else if (ViewBag.RB209ApiOption != null && ViewBag.RB209ApiOption == Resource.lblTrue)
                    {
                        <govuk-radios-item value="@Resource.lblYesUseTheseStandardNutrientValues">@Resource.lblYesUseTheseValues</govuk-radios-item>
                        <govuk-radios-item value="@Resource.lblYesUseTheseValues">@string.Format(Resource.lblNoIWantToUseTheUpdatedValuesFromDate, Model.DefaultFarmManureValueDate.Value.ToLocalTime().Date.ToString("dd MMMM yyyy", CultureInfo.GetCultureInfo("en-GB"))) </govuk-radios-item>
                        <govuk-radios-item value="@Resource.lblIwantToEnterARecentOrganicMaterialAnalysis">@Resource.lblIwantToEnterARecentOrganicMaterialAnalysis</govuk-radios-item>

                    }
                    else
                    {
                        <govuk-radios-item value="@Resource.lblYes">@Resource.lblYesUseTheseValues</govuk-radios-item>
                        <govuk-radios-item value="@Resource.lblIwantToEnterARecentOrganicMaterialAnalysis">
                            @(((Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials || Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials) && Model.DefaultFarmManureValueDate != null) ? Resource.lblIwantToEnterARecentOrganicMaterialAnalysis : Resource.lblNoChangeTheseValues)
                        </govuk-radios-item>
                    }
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>
        </form>
    </div>
</div>


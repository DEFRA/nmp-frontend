@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{string.Format(Resource.lblWouldYouLikeToUseTheseAnalysisValuesForFutureApplications, Model.ManureTypeName, Model.FarmName)} {Resource.lblHyphen} {title}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);

}
@section BeforeContent {
    <govuk-back-link asp-action="ManualNutrientValues" asp-controller="OrganicManure">@Resource.lblBack</govuk-back-link>
}

<form asp-action="NutrientValuesStoreForFuture" asp-controller="OrganicManure" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            @if (ViewBag.Error != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@ViewBag.Error</govuk-error-summary-item>
                </govuk-error-summary>
            }
           @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
            <govuk-radios for="@Model.IsAnyNeedToStoreNutrientValueForFuture">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @string.Format(Resource.lblWouldYouLikeToUseTheseAnalysisValuesForFutureApplications, Model.ManureTypeName, Model.FarmName)
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-hint>@Resource.lblNutrientValuesStoreForFutureHint</govuk-radios-hint>
                    <govuk-radios-item value="@yes" disabled="true">@Resource.lblYes</govuk-radios-item>
                    <govuk-radios-item value="@no">@Resource.lblNo</govuk-radios-item>
                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{Resource.lblTotalRainfallSinceApplication} {Resource.lblHyphen} {title}";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.OrganicManureWizardSteps.EffectiveRainfall;
}
@section BeforeContent {
    <govuk-back-link asp-action="ConditionsAffectingNutrients" asp-controller="OrganicManure">@Resource.lblBack</govuk-back-link>
}

<form asp-action="EffectiveRainfall" asp-controller="OrganicManure" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="govuk-grid-row">

        <div class="govuk-grid-column-two-thirds">
            @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
            <h1 class="govuk-heading-l">@Resource.lblTotalRainfallSinceApplication</h1>
            <p class="govuk-body">@Resource.lblThisIsTotalRainfall</p>
            <div class="text-group margin-bottom-forty">
                <h3 class="govuk-heading-s">@Resource.lblTotalRainfall</h3>
                <p class="govuk-body">@string.Concat(Model.TotalRainfall, Resource.lblmm)</p>
                <p class="govuk-body margin-bottom-forty">
                    <a class="govuk-link" asp-action="EffectiveRainfallManual" asp-controller="OrganicManure">@Resource.lblChange<span class="govuk-visually-hidden">@Resource.lblTotalRainfallSinceApplication</span></a>
                </p>

            </div>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>

            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
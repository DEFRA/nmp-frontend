@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{Resource.lblAutumnCropNitrogenUptake} {Resource.lblHyphen} {title}";

}
@section BeforeContent {
    <govuk-back-link asp-action="ConditionsAffectingNutrients" asp-controller="OrganicManure">@Resource.lblBack</govuk-back-link>
}

<form asp-action="AutumnCropNitrogenUptakeDetail" asp-controller="OrganicManure" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
            <h1 class="govuk-heading-l">
                @Resource.lblAutumnCropNitrogenUptake
            </h1>
            <p class="govuk-body">@Resource.lblThisIsTheAmountOfNitrogenFromTheApplication</p>

            <table class="govuk-table margin-bottom-forty">
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header">@Resource.lblFieldName</th>
                        <th scope="col" class="govuk-table__header">@Resource.lblCrop</th>
                        <th scope="col" class="govuk-table__header">@Resource.lblAutumnCropNitrogenNUptake</th>
                        <th scope="col" class="govuk-table__header"> </th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                    @if (Model.AutumnCropNitrogenUptakes != null && Model.AutumnCropNitrogenUptakes.Count > 0)
                    {
                        @foreach (var AutumnData in Model.AutumnCropNitrogenUptakes)
                        {
                            <tr class="govuk-table__row">
                                <td class="govuk-table__cell">@AutumnData.FieldName</td>
                                <td class="govuk-table__cell">@AutumnData.CropTypeName</td>
                                <td class="govuk-table__cell">@string.Format(Resource.lblAutumnKgPerHectare, (AutumnData.AutumnCropNitrogenUptake == 0.0m ? 0 : AutumnData.AutumnCropNitrogenUptake.ToString("#.#")))</td>
                                <td class="govuk-table__cell"><a asp-action="AutumnCropNitrogenUptake" asp-controller="OrganicManure" asp-route-f="@AutumnData.EncryptedFieldId">@Resource.lblChange<span class="govuk-visually-hidden">@Resource.lblAutumnCropNitrogenUptake</span></a></td>
                            </tr>
                        }
                    }

                </tbody>
            </table>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link"><a asp-action="ConditionsAffectingNutrients" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a></p>

        </div>

    </div>
</form>
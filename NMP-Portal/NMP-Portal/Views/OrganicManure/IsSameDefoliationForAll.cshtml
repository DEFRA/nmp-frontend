@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{Resource.lblForMultipleDefoliation} {Resource.lblHyphen} {title}";
    var count = 0;
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    string backAction = string.Empty;
    if (Model.IsCheckAnswer && (!Model.IsAnyChangeInField) && (!Model.IsManureTypeChange) && (!Model.IsDoubleCropValueChange))
    {
        backAction = "CheckAnswer";
    }
    else
    {
        if (Model.ManureGroupIdForFilter == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials || Model.ManureGroupIdForFilter == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials)
        {
            backAction = "ManureGroup";
        }
        if (Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherSolidMaterials || Model.ManureTypeId == (int)NMP.Commons.Enums.ManureTypes.OtherLiquidMaterials)
        {
            backAction="OtherMaterialName";
        }
        else
        {
            backAction = "ManureType";
        }
    }
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.OrganicManureWizardSteps.IsSameDefoliationForAll;
}

@section BeforeContent {
    @if (Model.IsCheckAnswer && (!Model.IsAnyChangeInField) && (!Model.IsDoubleCropValueChange) && (!Model.IsManureTypeChange))
    {
        <govuk-back-link asp-action="CheckAnswer" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedCounter">@Resource.lblBack</govuk-back-link>
    }
    else if (Model.IsDoubleCropAvailable || (Model.IsCheckAnswer && Model.IsDoubleCropValueChange))
    {
        <govuk-back-link asp-action="DoubleCrop" asp-controller="OrganicManure" asp-route-q="@Model.DoubleCropEncryptedCounter">@Resource.lblBack</govuk-back-link>
    }
    else
    {
        if (Model.FieldGroup == Resource.lblSelectSpecificFields)
        {
            backAction = "Fields";
        }
        else
        {
            backAction = "FieldGroup";
        }
        <govuk-back-link asp-action="@backAction" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedCounter">@Resource.lblBack</govuk-back-link>
    }
}
<div class="govuk-grid-row">
    @if (TempData["IsSameDefoliationForAllError"] != null)
    {
        <govuk-error-summary>
            <govuk-error-summary-item>@TempData["IsSameDefoliationForAllError"]</govuk-error-summary-item>
        </govuk-error-summary>
    }
    <form asp-action="IsSameDefoliationForAll" asp-controller="OrganicManure" method="post" autocomplete="off">
        @Html.AntiForgeryToken()

       @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-column-two-thirds">
            <govuk-radios for="@Model.IsSameDefoliationForAll">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Resource.lblForMultipleDefoliation
                    </govuk-radios-fieldset-legend>

                    <govuk-radios-item value=@yes>@Resource.lblYes</govuk-radios-item>
                    <govuk-radios-item value=@no>@Resource.lblNo</govuk-radios-item>

                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>

            <p class="govuk-body cancel-link">
                @if (string.IsNullOrWhiteSpace(Model.EncryptedOrgManureId) && (!Model.IsCheckAnswer))
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>
        </div>
    </form>
</div>
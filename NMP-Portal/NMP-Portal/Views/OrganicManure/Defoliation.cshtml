@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    ViewData["Title"] = Resource.lblDefoliation;
    var heading = "";
    if (Model.IsSameDefoliationForAll.HasValue && Model.IsSameDefoliationForAll.Value)
    {

        heading = ((Model.GrassCropCount != null && Model.GrassCropCount == 1) ? string.Format(Resource.lblWhichCutOrGrazingInThisApplicationForInField, Model.FieldName) : Resource.lblWhichCutOrGrazingInThisApplicationForAllField);
    }
    else
    {
        heading = string.Format(Resource.lblWhichCutOrGrazingInThisApplicationForInField, Model.FieldName);
    }
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";


    string defoliation = string.Empty;
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.OrganicManureWizardSteps.Defoliation;
}
@section BeforeContent {
    <govuk-back-link asp-action=@((Model.IsCheckAnswer && (!Model.IsAnyChangeInField) && (!Model.IsManureTypeChange) && (!Model.IsAnyChangeInSameDefoliationFlag) && (!Model.IsDoubleCropValueChange)) ? "CheckAnswer" : "Defoliation") asp-controller="OrganicManure" asp-route-q="@Model.DefoliationEncryptedCounter">@Resource.lblBack</govuk-back-link>
}



<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @if (TempData["DefoliationError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item>@TempData["DefoliationError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }
        <form asp-action="Defoliation" asp-controller="OrganicManure" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

         @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
            @if (Model.DefoliationList != null && Model.DefoliationList.Count > 0 && Model.OrganicManures.Any(x => x.IsGrass))
            {
                @for (int i = 0; i < Model.DefoliationList.Count; i++)
                {
                    <div hidden="true">
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].ManagementPeriodID" value="@Model.DefoliationList[i].ManagementPeriodID" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].CropID" value="@Model.DefoliationList[i].CropID" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].FieldName" value="@Model.DefoliationList[i].FieldName" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].FieldID" value="@Model.DefoliationList[i].FieldID" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].DefoliationName" value="@Model.DefoliationList[i].DefoliationName" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].EncryptedCounter" value="@Model.DefoliationList[i].EncryptedCounter" />
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].Counter" value="@Model.DefoliationList[i].Counter" />
                    </div>
                    @if (Model.DefoliationCurrentCounter == i)
                    {
                        <govuk-radios asp-for="@Model.DefoliationList[i].Defoliation">
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                                    @if (Model.IsSameDefoliationForAll.HasValue && Model.IsSameDefoliationForAll.Value && Model.GrassCropCount > 1)
                                    {
                                        @((Model.GrassCropCount != null && Model.GrassCropCount == 1) ? string.Format(Resource.lblWhichCutOrGrazingInThisApplicationForInField, Model.FieldName) : Resource.lblWhichCutOrGrazingInThisApplicationForAllField)
                                                }
                                    else
                                    {
                                        @string.Format(Resource.lblWhichCutOrGrazingInThisApplicationForInField, Model.FieldName)
                                    }
                                </govuk-radios-fieldset-legend>
                                <govuk-radios-hint>@Resource.lblSelectOneOption</govuk-radios-hint>
                                @if (ViewBag.DefoliationList != null)
                                {
                                    @foreach (var item in ViewBag.DefoliationList)
                                    {
                                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                                    }
                                }

                            </govuk-radios-fieldset>
                        </govuk-radios>
                    }
                    else
                    {
                        <div hidden="true">
                            <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].Defoliation" value="@Model.DefoliationList[i].Defoliation" />
                        </div>
                    }
                }
            }
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>
        </form>
    </div>

</div>


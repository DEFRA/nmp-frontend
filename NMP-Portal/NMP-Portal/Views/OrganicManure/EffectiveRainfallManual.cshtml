@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.OrganicManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedOrgManureId)) ? Resource.lblUpdateOrganicManure : Resource.lblAddOrganicManure;
    ViewData["Title"] = $"{Resource.lblEnterRainfallAmount} {Resource.lblHyphen} {title}";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.OrganicManureWizardSteps.EffectiveRainfallManual;
}
@section BeforeContent {
    <govuk-back-link asp-action="EffectiveRainfall" asp-controller="OrganicManure">@Resource.lblBack</govuk-back-link>
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="EffectiveRainfallManual" asp-controller="OrganicManure" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
       @await Html.PartialAsync("~/Views/OrganicManure/_OrganicManureWizardHiddenFields.cshtml", Model)
            <govuk-input for=@Model.TotalRainfall input-class="govuk-input--width-5" inputmode="numeric" spellcheck="false">
                <govuk-input-label is-page-heading="true" class="govuk-label--l">
                    @Resource.lblWhatWasTheTotalRainfallSinceApplicationSuffix<span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblmm)</span>@Resource.lblQuestionMark
                </govuk-input-label>
                <govuk-input-suffix>@Resource.lblmm</govuk-input-suffix>
            </govuk-input>
            <fieldset class="govuk-fieldset">
                <br>
                <govuk-button type="submit">@Resource.lblContinue</govuk-button>
            </fieldset>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>
        </form>
    </div>
</div>

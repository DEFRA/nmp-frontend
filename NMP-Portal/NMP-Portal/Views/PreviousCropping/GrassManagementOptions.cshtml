@using NMP.Commons.Resources
@using NMP.Commons.Enums
@model NMP.Commons.ViewModels.PreviousCroppingViewModel
@{
    //ViewData["Title"] = Resource.lblGrassManagementOptions;
    ViewData["Title"] = $"{Resource.lblHowWasTheGrassTypicallyManagedEachYear} {Resource.lblHyphen} {Resource.lblAddPreviousCrop}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    var backAction = "";
    if (Model.IsCheckAnswer)
    {
        backAction = "CheckAnswer";
    }
    else if (Model.PreviousGrassYears?.All(x => x < Model.HarvestYear) == true)
    {
        backAction = "LayDuration";
    }
    else
    {
        backAction = "GrassLastThreeHarvestYear";
    }
    ViewBag.CurrentStep = (int)PreviousCroppingWizardSteps.GrassManagementOption;
}

@section BeforeContent {
    <govuk-back-link asp-action=@backAction asp-controller="PreviousCropping">@Resource.lblBack</govuk-back-link>
}
<form asp-action="GrassManagementOptions" asp-controller="PreviousCropping" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/PreviousCropping/_PreviousCroppingHiddenField.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-radios class="govuk-radios" asp-for="@Model.GrassManagementOptionID">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Resource.lblHowWasTheGrassTypicallyManagedEachYear
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-hint>@Resource.lblTypicalManagedQuestionHint</govuk-radios-hint>
                    @if (ViewBag.GrassManagementOptions != null)
                    {
                        @foreach (var item in ViewBag.GrassManagementOptions)
                        {
                            <govuk-radios-item value="@item.Id">@item.Name</govuk-radios-item>
                        }
                    }
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="Recommendations" asp-controller="Crop" asp-route-q="@Model.EncryptedFarmID" asp-route-r="@Model.EncryptedFieldID" asp-route-s="@Model.EncryptedYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="PreviousCropping">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
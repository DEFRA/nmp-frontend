@using NMP.Commons.Resources
@using NMP.Commons.ViewModels
@using NMP.Commons.Enums
@model SoilAnalysisViewModel

@{
    ViewData["Title"] = (Model != null && (!string.IsNullOrWhiteSpace(Model.EncryptedSoilAnalysisId)))
    ? $"{string.Format(Resource.lblAddSoilAnalysis, Model.FieldName)} {Resource.lblHyphen} {Resource.lblUpdateSoilAnalysis}" :
    $"{string.Format(Resource.lblAddSoilAnalysis, Model.FieldName)} {Resource.lblHyphen} {Resource.lblAddASoilAnalysis}";
    var isOlderThanFiveYears = false;
    var currentYear = System.DateTime.Now.Year;
    if (Model.Date != null && Model.Date.Value.Year < currentYear)
    {
        var yearGap = currentYear - Model.Date.Value.Year;
        if (yearGap > 5)
        {
            isOlderThanFiveYears = true;
        }
    }
    var isFieldsEmpty = false;
    if (ViewData["IsPostRequest"] != null)
    {
        isFieldsEmpty = Model.PH == null && ((Model.PhosphorusIndex == null && string.IsNullOrWhiteSpace(Model.PotassiumIndexValue) && Model.MagnesiumIndex == null)
        || (Model.Phosphorus == null && Model.Potassium == null && Model.Magnesium == null));
    }
    ViewBag.CurrentStep = (int)SoilAnalysisWizardSteps.SoilNutrientValue;
}


@section BeforeContent {
    @if (Model.isSoilAnalysisAdded != null && Model.isSoilAnalysisAdded.Value && (!Model.IsCheckAnswer))
    {
        <govuk-back-link asp-action="@(Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland ? "SoilAnalysesMethod" : "SoilNutrientValueType")" asp-controller="SoilAnalysis">@Resource.lblBack</govuk-back-link>
    }
    else
    {
        <govuk-back-link asp-action=@(!Model.IsSoilNutrientValueTypeChange ? "ChangeSoilAnalysis" : "SoilNutrientValueType") asp-controller="SoilAnalysis" asp-route-i="@Model.EncryptedSoilAnalysisId" asp-route-j="@Model.EncryptedFieldId" asp-route-k="@Model.EncryptedFarmId" asp-route-l="@Model.IsSoilDataChanged">@Resource.lblBack</govuk-back-link>
    }
}
@if (ViewBag.Error != null)
{
    <govuk-error-summary>
        <govuk-error-summary-item href="#">@ViewBag.Error</govuk-error-summary-item>
    </govuk-error-summary>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="SoilNutrientValue" method="post" autocomplete="off" asp-controller="SoilAnalysis">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/SoilAnalysis/_SoilAnalysisWizardHiddenFields.cshtml", Model)

            @if (isFieldsEmpty)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#PH">@Resource.MsgForPhPhosphorusPotassiumMagnesium</govuk-error-summary-item>
                </govuk-error-summary>
            }

            <div class="govuk-form-group @(isFieldsEmpty ? "govuk-form-group--error" : "")">
                <govuk-fieldset>
                    <govuk-fieldset-legend class="govuk-fieldset__legend--l">
                        <h1 class="govuk-fieldset__heading">@string.Format(Resource.lblAddSoilAnalysis, Model.FieldName)</h1>
                    </govuk-fieldset-legend>
                    @if (isOlderThanFiveYears)
                    {
                        <govuk-inset-text>
                            @Resource.MsgSoilAnalysisOlderThanFiveYears
                        </govuk-inset-text>
                    }
                    <p class="govuk-body">
                        @Resource.MsgEnterTheValueOYourSoilAnalysisHint1
                    </p>
                    @if (isFieldsEmpty)
                    {
                        <govuk-error-message asp-for="@Model.PH">
                            @Resource.MsgForPhPhosphorusPotassiumMagnesium
                        </govuk-error-message>
                    }
                    <govuk-input asp-for="@Model.PH" input-class="govuk-input--width-5" spellcheck="false" type="number" step="any">
                        <govuk-input-label is-page-heading="false">@Resource.lblPHLevelOption</govuk-input-label>
                    </govuk-input>
                    @if (Model.FarmRB209CountryID.HasValue && Model.FarmRB209CountryID.Value != (int)NMP.Commons.Enums.RB209Country.Scotland && Model.SoilNutrientValueType.HasValue && Model.SoilNutrientValueType == (int)NMP.Commons.Enums.SoilNutrientValueType.Index)
                    {

                        <govuk-input asp-for="@Model.PhosphorusIndex" type="number" step="1" input-class="govuk-input--width-5">
                            <govuk-input-label is-page-heading="false">@Resource.lblPhosphorusIndexOptional</govuk-input-label>
                        </govuk-input>

                        <govuk-input input-class="govuk-input--width-5" asp-for="@Model.PotassiumIndexValue">
                            <govuk-input-label is-page-heading="false">@Resource.lblPotassiumIndexOptional</govuk-input-label>
                            <govuk-input-hint>@Resource.MsgEnterTheValueOYourSoilAnalysisHint3</govuk-input-hint>
                        </govuk-input>

                        <govuk-input input-class="govuk-input--width-5" asp-for="@Model.MagnesiumIndex" type="number" step="1">
                            <govuk-input-label is-page-heading="false">@Resource.lblMagnesiumIndexOptional</govuk-input-label>
                        </govuk-input>

                    }
                    else
                    @if (Model.SoilNutrientValueType.HasValue && Model.SoilNutrientValueType == (int)NMP.Commons.Enums.SoilNutrientValueType.Miligram)
                    {

                        <govuk-input asp-for=@Model.Phosphorus type="number" step="1" input-class="govuk-input--width-5" spellcheck="false">
                            <govuk-input-label is-page-heading="false">
                                @Resource.lblPhosphorusPerLitreOfSoil
                                <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblMgL)</span>
                                @Resource.lblOptional
                            </govuk-input-label>
                            <govuk-input-suffix>@Resource.lblMgL</govuk-input-suffix>
                        </govuk-input>
                        <govuk-input asp-for=@Model.Potassium type="number" step="1" input-class="govuk-input--width-5" spellcheck="false">
                            <govuk-input-label is-page-heading="false">
                                @Resource.lblPotassiumPerLitreOfSoil
                                <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblMgL)</span>
                                @Resource.lblOptional
                            </govuk-input-label>
                            <govuk-input-suffix>@Resource.lblMgL</govuk-input-suffix>
                        </govuk-input>
                        <govuk-input asp-for=@Model.Magnesium type="number" step="1" input-class="govuk-input--width-5" spellcheck="false">
                            <govuk-input-label is-page-heading="false">
                                @Resource.lblMagnesiumPerLitreOfSoil
                                <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblMgL)</span>
                                @Resource.lblOptional
                            </govuk-input-label>
                            <govuk-input-suffix>@Resource.lblMgL</govuk-input-suffix>
                        </govuk-input>

                    }
                    else
                    @if (Model.FarmRB209CountryID.HasValue && Model.FarmRB209CountryID.Value == (int)NMP.Commons.Enums.RB209Country.Scotland)
                    {
                        <govuk-radios asp-for="@Model.PhosphorusStatus">
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="false">
                                    @Resource.lblPhosphorusStatusOptional
                                </govuk-radios-fieldset-legend>

                                @if (ViewBag.PhosphorusSelectList != null)
                                {
                                    @foreach (var item in ViewBag.PhosphorusSelectList)
                                    {
                                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                                    }
                                }

                            </govuk-radios-fieldset>
                        </govuk-radios>
                        <govuk-radios asp-for="@Model.PotassiumStatus">
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="false">
                                    @Resource.lblPotashStatusOptional
                                </govuk-radios-fieldset-legend>

                                @if (ViewBag.PhosphorusSelectList != null)
                                {
                                    @foreach (var item in ViewBag.PhosphorusSelectList)
                                    {
                                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                                    }
                                }

                            </govuk-radios-fieldset>
                        </govuk-radios>
                        <govuk-radios asp-for="@Model.MagnesiumStatus">
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="false">
                                    @Resource.lblMagnesiumStatusOptional
                                </govuk-radios-fieldset-legend>

                                @if (ViewBag.MagnesiumSelectList != null)
                                {
                                    @foreach (var item in ViewBag.MagnesiumSelectList)
                                    {
                                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                                    }
                                }

                            </govuk-radios-fieldset>
                        </govuk-radios>


                    }

                </govuk-fieldset>
            </div>

            <govuk-input asp-for=@Model.OrganicMatterPercentage type="number" input-class="govuk-input--width-5" spellcheck="false">
                <govuk-input-label is-page-heading="false">
                    @Resource.lblOrganicMatter
                    <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblPercentage)</span>@Resource.lblOptional
                </govuk-input-label>
                <govuk-input-suffix>@Resource.lblPercentage</govuk-input-suffix>
            </govuk-input>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>


            @await Html.PartialAsync("~/Views/SoilAnalysis/_CancelAction.cshtml", Model)
        </form>

    </div>
</div>
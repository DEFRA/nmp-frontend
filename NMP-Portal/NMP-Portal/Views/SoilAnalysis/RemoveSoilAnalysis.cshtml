﻿@using NMP.Commons.Resources
﻿@using NMP.Commons.Enums
@using System.Globalization
@using NMP.Commons.ViewModels

@model SoilAnalysisViewModel
@{
    ViewData["Title"] = $"{string.Format(Resource.lblRemoveSoilAnalysisFromFieldName, Model.FieldName)} {Resource.lblHyphen} {Resource.lblSoilAnalysis} {Resource.lblRemove}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    ViewBag.CurrentStep = (int)SoilAnalysisWizardSteps.RemoveSoilAnalysis;
}

@if (Model != null)
{
    @section BeforeContent {
        <govuk-back-link asp-action="ChangeSoilAnalysis" asp-controller="SoilAnalysis" asp-route-i="@Model.EncryptedSoilAnalysisId" asp-route-j="@Model.EncryptedFieldId" asp-route-k="@Model.EncryptedFarmId" asp-route-l="@Model.IsSoilDataChanged">@Resource.lblBack</govuk-back-link>
    }
    <form asp-action="RemoveSoilAnalysis" asp-controller="SoilAnalysis" method="post" autocomplete="off">
        @Html.AntiForgeryToken()

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds-from-desktop">
                @if (TempData["RemoveSoilAnalysisError"] != null)
                {
                    <govuk-error-summary>
                        <govuk-error-summary-item href="#">@TempData["RemoveSoilAnalysisError"]</govuk-error-summary-item>
                    </govuk-error-summary>
                }
                @await Html.PartialAsync("~/Views/SoilAnalysis/_SoilAnalysisWizardHiddenFields.cshtml", Model)
                <govuk-fieldset>
                    <govuk-fieldset-legend class="govuk-fieldset__legend--l">
                        <h1 class="govuk-fieldset__heading">@string.Format(Resource.lblRemoveSoilAnalysisFromFieldName, Model.FieldName)</h1>
                    </govuk-fieldset-legend>
                    <p class="govuk-body">
                        @string.Format(Resource.lblRemoveSoilAnalysisContentFirst, Model.FieldName)
                    </p>
                    <govuk-radios class="govuk-radios--inline" asp-for="@Model.SoilAnalysisRemove">
                        <govuk-radios-fieldset>
                            <govuk-radios-fieldset-legend>
                                @Resource.lblAreYouSureYouWantToContinue
                            </govuk-radios-fieldset-legend>
                            <govuk-radios-item value="@yes">@Resource.lblYes</govuk-radios-item>
                            <govuk-radios-item value="@no">@Resource.lblNo</govuk-radios-item>
                        </govuk-radios-fieldset>
                    </govuk-radios>
                </govuk-fieldset>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>

                <p class="govuk-body cancel-link"><a asp-action="FieldSoilAnalysisDetail" asp-controller="Field" asp-route-farmId="@Model.EncryptedFarmId" asp-route-fieldId="@Model.EncryptedFieldId">@Resource.lblCancel</a></p>
            </div>
        </div>
    </form>

}
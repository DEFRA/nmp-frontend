@using NMP.Commons.Resources
@using NMP.Commons.Enums
@using NMP.Commons.ViewModels
@model FieldViewModel

@{
    string title = (Model != null && !string.IsNullOrEmpty(Model.EncryptedIsUpdate)) ? $"{Resource.lblWhatIsTheLPIDNumber} {Resource.lblHyphen} {Resource.lblUpdateField}" : $"{Resource.lblWhatIsTheLPIDNumber} {Resource.lblHyphen} {Resource.lblAddField}";
    ViewData["Title"] = title;
    var cancelAction = "CheckAnswer";
    if (Model != null && !Model.IsCheckAnswer)
    {
        cancelAction = (!string.IsNullOrWhiteSpace(Model.EncryptedFieldId)) ? "UpdateField" :
          "CreateFieldCancel";
    }

    var cancelRouteId =
        (cancelAction == "CreateFieldCancel" && Model != null) ? Model.EncryptedFarmId : null; 
        ViewBag.CurrentStep = (int)FieldWizardSteps.LPIDNumber;
}

@section BeforeContent {
    <govuk-back-link asp-action="@(Model != null && Model.IsCheckAnswer ? "CheckAnswer" : "AddField")" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblBack</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @if (TempData["LPIDNumberError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item href="#LPIDNumber">@TempData["LPIDNumberError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }
        <form asp-action="LPIDNumber" method="post" asp-controller="Field" autocomplete="off">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
            <govuk-input asp-for="LPIDNumber">
                <govuk-input-label is-page-heading="true" class="govuk-label--l">
                    @Resource.lblWhatIsTheLPIDNumber
                </govuk-input-label>
                <govuk-input-hint>@Resource.lblHintOfLPIDNumber</govuk-input-hint>
            </govuk-input>

            <govuk-button type="submit" data-prevent-double-click="true" class="govuk-button margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
        </form>
        <p class="govuk-body cancel-link">
            <a asp-action="@cancelAction"
               asp-controller="Field"
               asp-route-id="@cancelRouteId">
                @Resource.lblCancel
            </a>
        </p>
    </div>
</div>

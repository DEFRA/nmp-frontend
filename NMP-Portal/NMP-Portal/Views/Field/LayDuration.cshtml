@using NMP.Commons.Enums
@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.FieldViewModel
@{
    //ViewData["Title"] = Resource.lblLayDuration;
    string title = (Model != null && !string.IsNullOrEmpty(Model.EncryptedIsUpdate)) ? Resource.lblUpdateField : Resource.lblAddField;
    ViewData["Title"] = $"{string.Format(Resource.lblWhatWasTheLengthOfTheLayInYear, Model.PreviousGrassYears?[0])} {Resource.lblHyphen} {title}";
    var oneToTwoYears = (int)NMP.Commons.Enums.LayDuration.OneToTwoYears;
    var threeYearsOrMore = (int)NMP.Commons.Enums.LayDuration.ThreeYearsOrMore;
    var backAction = "";
    if (Model.IsCheckAnswer && (!Model.IsHasGrassInLastThreeYearChange))
    {
        backAction = "CheckAnswer";
    }
    else if (!string.IsNullOrWhiteSpace(Model.EncryptedIsUpdate))
    {
        backAction = "UpdateField";
    }
    else
    {
        backAction = "GrassLastThreeHarvestYear";
    }
    ViewBag.CurrentStep = (int)FieldWizardSteps.LayDuration;
}

@section BeforeContent {
    <govuk-back-link asp-action=@backAction asp-controller="Field">@Resource.lblBack</govuk-back-link>
}
<form asp-action="LayDuration" asp-controller="Field" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-radios class="govuk-radios" asp-for="@Model.PreviousCroppings.LayDuration">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @string.Format(Resource.lblWhatWasTheLengthOfTheLayInYear, Model.PreviousGrassYears?[0])
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-item value="@oneToTwoYears">@Resource.lbl1To2Years</govuk-radios-item>
                    <govuk-radios-item value="@threeYearsOrMore">@Resource.lbl3YearsOrMore</govuk-radios-item>
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!string.IsNullOrWhiteSpace(Model.EncryptedFieldId))
                {
                    <a asp-action="UpdateField" asp-controller="Field">@Resource.lblCancel</a>
                }
                else if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateFieldCancel" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="Field">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
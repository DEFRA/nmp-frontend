@using NMP.Commons.Resources
@using NMP.Commons.Enums
@model NMP.Commons.ViewModels.FieldViewModel
@{
    ViewData["Title"] = (Model != null && !string.IsNullOrEmpty(Model.EncryptedIsUpdate)) ? $"{string.Format(Resource.lblWhatWasThePreviousCropGroup, Model.LastHarvestYear)} {Resource.lblHyphen} {Resource.lblUpdateField}" : $"{string.Format(Resource.lblWhatWasThePreviousCropGroup, Model.LastHarvestYear)} {Resource.lblHyphen} {Resource.lblAddField}";
    int grassGroupId = (int)NMP.Commons.Enums.CropGroup.Grass;

    var backAction = "";
    if (Model.PreviousCroppings.HasGrassInLastThreeYear.HasValue)
    {
        if (Model.IsCheckAnswer)
        {
            backAction = "CheckAnswer";
        }
        else if (!string.IsNullOrWhiteSpace(Model.EncryptedIsUpdate))
        {
            backAction = "UpdateField";
        }
        else if (Model.PreviousCroppings.HasGrassInLastThreeYear.Value)
        {
            if (Model.PreviousCroppings.HasGreaterThan30PercentClover.HasValue && !Model.PreviousCroppings.HasGreaterThan30PercentClover.Value)
            {
                backAction = "SoilNitrogenSupplyItems";
            }
            else
            {
                backAction = "HasGreaterThan30PercentClover";
            }
        }
        else if (Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland)
        {
            backAction = "LastHarvestYear";
        }
        else
        {
            backAction = "HasGrassInLastThreeYear";
        }

    }
    else
    {
        if (Model.RecentSoilAnalysisQuestion.HasValue && Model.RecentSoilAnalysisQuestion.Value)
        {
            backAction = "SoilNutrientValue";
        }
        backAction = "RecentSoilAnalysisQuestion";
    }
    ViewBag.CurrentStep = (int)FieldWizardSteps.CropGroup;
}

@section BeforeContent {
    <govuk-back-link asp-action="@((Model.IsCheckAnswer && (!Model.IsHasGrassInLastThreeYearChange)) ? "CheckAnswer" : backAction)" asp-controller="Field">@Resource.lblBack</govuk-back-link>
}
<form asp-action="CropGroups" asp-controller="Field" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            @if (TempData["Error"] != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["Error"]</govuk-error-summary-item>
                </govuk-error-summary>
            }

            <govuk-radios asp-for="@Model.CropGroupId">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @* @(Model.WantToApplySns == true ? Resource.lblWhatWasThePreviousCropGroup : Resource.lblWhatIsTheCurrentCropGroup) *@
                        @string.Format(Resource.lblWhatWasThePreviousCropGroup, Model.LastHarvestYear)
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-hint>@string.Format(Resource.lblTheseOptionsComeFromRB209, Resource.lblCropGroups)</govuk-radios-hint>

                    @if (ViewBag.CropGroupList != null)
                    {
                        @foreach (var item in ViewBag.CropGroupList)
                        {
                            @if (item.CropGroupId == grassGroupId)
                            {
                                <govuk-radios-item value="@item.CropGroupId" disabled="true">@item.CropGroupName</govuk-radios-item>
                            }
                            else
                            {
                                <govuk-radios-item value="@item.CropGroupId">@item.CropGroupName</govuk-radios-item>
                            }
                        }
                    }

                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateFieldCancel" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="Field">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
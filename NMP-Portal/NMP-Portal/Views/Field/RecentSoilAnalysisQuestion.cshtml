@using NMP.Commons.Resources
@using NMP.Commons.Enums
@model NMP.Commons.ViewModels.FieldViewModel
@{    
    ViewData["Title"] = $"{string.Format(Resource.lblDoYouWantToAddARecentSoilAnalysis, Model.Name)} {Resource.lblHyphen} {Resource.lblAddField}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    var backAction = "";

     if (Model.FarmRB209CountryID.HasValue && Model.FarmRB209CountryID.Value == (int)NMP.Commons.Enums.RB209Country.Scotland)
    {
        backAction = "PscIndex";
    }
    else if(Model.IsSoilReleasingClay)
    {
        backAction = "SoilReleasingClay";
    }
    else if (Model.SoilOverChalk != null)
    {
        backAction = "SoilOverChalk";
    }
    else
    {
        backAction = "SoilType";
        if(Model.CopyExistingField.HasValue&&Model.CopyExistingField.Value)
        {
            backAction = "AddField";
        }
    }
    ViewBag.CurrentStep = (int)FieldWizardSteps.RecentSoilAnalysisQuestion;
}

@section BeforeContent {
    <govuk-back-link asp-action="@(Model.IsCheckAnswer ? "CheckAnswer" : backAction)" asp-controller="Field" asp-route-q="@Model.EncryptedFarmId">@Resource.lblBack</govuk-back-link>
}
<form asp-action="RecentSoilAnalysisQuestion" asp-controller="Field" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            @if (TempData["Error"] != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["Error"]</govuk-error-summary-item>
                </govuk-error-summary>
            } 
            <h1 class="govuk-heading-l">@string.Format(Resource.lblDoYouWantToAddARecentSoilAnalysis, Model.Name)</h1>
            <p class="govuk-body">
                @Resource.MsgSoilAnalysisHint1
            </p>            
            <p class="govuk-body margin-bottom-forty">
                @Resource.MsgSoilAnalysisHint3
            </p>
            <govuk-radios class="govuk-radios--inline" asp-for="@Model.RecentSoilAnalysisQuestion">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="false">
                        @string.Format(Resource.lblDoYouWantToAddSoilAnalysisFor, Model.Name)                           
                    </govuk-radios-fieldset-legend>
                    
                    <govuk-radios-item value=@yes>@Resource.lblYes</govuk-radios-item>
                    <govuk-radios-item value=@no>@Resource.lblNo</govuk-radios-item>
                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateFieldCancel" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="Field">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
@using NMP.Commons.Resources
@using NMP.Commons.Enums
@model NMP.Commons.ViewModels.FieldViewModel
@{
    string heading = Resource.lblIsTheSoilOverChalk;
    string title = (Model != null && !string.IsNullOrEmpty(Model.EncryptedIsUpdate)) ? Resource.lblUpdateField : Resource.lblAddField;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    var backAction = (Model != null && Model.IsCheckAnswer ? "CheckAnswer" : "SoilType");

    var cancelAction = "CheckAnswer";
    if (Model != null && !Model.IsCheckAnswer)
    {
        cancelAction = (!string.IsNullOrWhiteSpace(Model.EncryptedFieldId)) ? "UpdateField" :
          "CreateFieldCancel";
    }

    var cancelRouteId =
        (cancelAction == "CreateFieldCancel" && Model != null) ? Model.EncryptedFarmId : null;
        ViewBag.CurrentStep = (int)FieldWizardSteps.SoilOverChalk;
}

@section BeforeContent {
    <govuk-back-link asp-action=@backAction asp-controller="Field">@Resource.lblBack</govuk-back-link>
}
<form asp-action="SoilOverChalk" asp-controller="Field" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-radios class="govuk-radios--inline" asp-for="@Model.SoilOverChalk">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @heading
                    </govuk-radios-fieldset-legend>
                    <govuk-radios-item value=@yes>@Resource.lblYes</govuk-radios-item>
                    <govuk-radios-item value=@no>@Resource.lblNo</govuk-radios-item>
                </govuk-radios-fieldset>
            </govuk-radios>

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                <a asp-action="@cancelAction"
                   asp-controller="Field"
                   asp-route-id="@cancelRouteId">
                    @Resource.lblCancel
                </a>
            </p>

        </div>

    </div>
</form>
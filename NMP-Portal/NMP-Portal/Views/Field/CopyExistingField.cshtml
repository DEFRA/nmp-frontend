@using NMP.Commons.Resources
@using NMP.Commons.Enums
@using NMP.Commons.ViewModels
@model FieldViewModel

@{
    //ViewData["Title"] = Resource.lblCopyExistingField;
    ViewData["Title"] = $"{Resource.lblDoYouWantToCopyAnExistingField} {Resource.lblHyphen} {Resource.lblAddField}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);   
    ViewBag.CurrentStep = (int)FieldWizardSteps.CopyExistingField;
}

@section BeforeContent {
    <govuk-back-link asp-action="ManageFarmFields" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblBack</govuk-back-link>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        @* <h1 class="govuk-heading-l">@Resource.lblDoYouWantToCopyAnExistingField</h1> *@
        @if (TempData["CopyExistingFieldError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item>@TempData["CopyExistingFieldError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }
     
        <form asp-action="CopyExistingField" method="post" asp-controller="Field" autocomplete="off">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
            <govuk-radios class="govuk-radios--inline"  asp-for="@Model.CopyExistingField">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend  is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Resource.lblDoYouWantToCopyAnExistingField
                    </govuk-radios-fieldset-legend>                    
                    <govuk-radios-item  value=@yes>@Resource.lblYes</govuk-radios-item>
                    <govuk-radios-item value=@no>@Resource.lblNo</govuk-radios-item>
                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" data-prevent-double-click="true" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
        </form>
        <p class="govuk-body cancel-link">
            @if (!Model.IsCheckAnswer)
            {
                <a asp-action="CreateFieldCancel" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblCancel</a>
            }
            else
            {
                <a asp-action="CheckAnswer" asp-controller="Field">@Resource.lblCancel</a>
            }
        </p>
    </div>
</div>
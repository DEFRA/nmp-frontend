@using NMP.Commons.Resources
@using NMP.Commons.Enums
@model NMP.Commons.ViewModels.FieldViewModel
@{
    //ViewData["Title"] = Resource.lblHasGrassInLastThreeYear;
    string title = (Model != null && !string.IsNullOrEmpty(Model.EncryptedIsUpdate)) ? Resource.lblUpdateField : Resource.lblAddField;
    ViewData["Title"] = $"{string.Format(Resource.lblInWhichYearsWasUsedForGrass, Model.Name)} {Resource.lblHyphen} {title}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    var backAction = "";
    if (Model.IsCheckAnswer && (!Model.IsHasGrassInLastThreeYearChange))
    {
        backAction = "CheckAnswer";
    }
    else if (!string.IsNullOrWhiteSpace(Model.EncryptedIsUpdate))
    {
        backAction = "UpdateField";
    }
    else
    {
        backAction = "HasGrassInLastThreeYear";
    }
    ViewBag.CurrentStep = (int)FieldWizardSteps.GrassLastThreeHarvestYear;
}

@section BeforeContent {
    <govuk-back-link asp-action=@backAction asp-controller="Field">@Resource.lblBack</govuk-back-link>
}
<form asp-action="GrassLastThreeHarvestYear" asp-controller="Field" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("~/Views/Field/_FieldWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
                <govuk-checkboxes name="PreviousGrassYears" asp-for="PreviousGrassYears">
                    <govuk-checkboxes-fieldset>
                        <govuk-checkboxes-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                            @string.Format(Resource.lblInWhichYearsWasUsedForGrass, Model.Name)
                        </govuk-checkboxes-fieldset-legend>

                        <govuk-checkboxes-hint>
                            @Resource.lblSelectAllThatApply
                        </govuk-checkboxes-hint>
                        @if (ViewBag.PreviousCroppingsYear != null)
                        {
                            @foreach (var item in ViewBag.PreviousCroppingsYear)
                            {
                            <govuk-checkboxes-item value="@item">@item</govuk-checkboxes-item>
                            }
                        }

                        <govuk-checkboxes-divider>or</govuk-checkboxes-divider>
                    <govuk-checkboxes-item value="0" id="select-all" name="select-all">@Resource.lblSelectAll</govuk-checkboxes-item>
                    </govuk-checkboxes-fieldset>
                </govuk-checkboxes>
            
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!string.IsNullOrWhiteSpace(Model.EncryptedFieldId))
                {
                    <a asp-action="UpdateField" asp-controller="Field">@Resource.lblCancel</a>
                }
                else if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateFieldCancel" asp-controller="Field" asp-route-id="@Model.EncryptedFarmId">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="Field">@Resource.lblCancel</a>
                }
            </p>

        </div>

    </div>
</form>
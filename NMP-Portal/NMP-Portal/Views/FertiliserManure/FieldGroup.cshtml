@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.FertiliserManureViewModel
@{
    string title = (!string.IsNullOrEmpty(Model.EncryptedFertId)) ? Resource.lblUpdateInorganicFeriliser : Resource.lblAddInorganicFeriliser;
    ViewData["Title"] = $"{Resource.lblWhichFieldsWouldYouLikeToAddInorganicFertiliserApplications} {Resource.lblHyphen} {title}";
    
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.FertiliserWizardSteps.FieldGroup;
}

@section BeforeContent {
    <govuk-back-link asp-action=@(Model.IsCheckAnswer?"CheckAnswer":"HarvestYearOverview") asp-controller=@(Model.IsCheckAnswer?"FertiliserManure":"Crop") asp-route-id="@Model.EncryptedFarmId" asp-route-year="@Model.EncryptedHarvestYear">@Resource.lblBack</govuk-back-link>
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="FieldGroup" asp-controller="FertiliserManure" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("~/Views/FertiliserManure/_FertiliserWizardHiddenFields.cshtml", Model)
            @if (TempData["FieldGroupError"] != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item href="#">@TempData["FieldGroupError"]</govuk-error-summary-item>
                </govuk-error-summary>
            }


            <govuk-radios for="@Model.FieldGroup">
                <govuk-radios-fieldset>
                    <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @Resource.lblWhichFieldsWouldYouLikeToAddInorganicFertiliserApplications
                    </govuk-radios-fieldset-legend>

                    @if (ViewBag.FieldGroupList != null)
                    {
                        @foreach (var item in ViewBag.FieldGroupList)
                        {
                            <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>

                        }
                    }

                </govuk-radios-fieldset>
            </govuk-radios>
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateFertiliserManureCancel" asp-controller="FertiliserManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="FertiliserManure">@Resource.lblCancel</a>
                }
            </p>

        </form>

    </div>

</div>
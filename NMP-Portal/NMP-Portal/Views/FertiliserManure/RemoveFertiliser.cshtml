﻿@using NMP.Commons.Resources
@using System.Globalization
@using NMP.Commons.ViewModels

@model FertiliserManureViewModel
@{
    var heading = (!string.IsNullOrWhiteSpace(Model.FieldName)) ? (string.Format(Resource.lblRemoveAnInorganicFertiliserApplicationFromField, Model.FieldName)) : Resource.lblRemoveAnInorganicFertiliserApplication;
    string title = (!string.IsNullOrEmpty(Model.EncryptedFertId)) ? Resource.lblUpdateInorganicFeriliser : Resource.lblAddInorganicFeriliser;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";

    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.FertiliserWizardSteps.IsDeleteFertliser;
}

@if (Model != null)
{

    @section BeforeContent {
            <govuk-back-link asp-action="CheckAnswer" asp-controller="FertiliserManure">
                @Resource.lblBack
            </govuk-back-link>

    }
    <form asp-action="RemoveFertiliser" asp-controller="FertiliserManure" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/FertiliserManure/_FertiliserWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds-from-desktop">
                @if (TempData["RemoveFertiliserError"] != null)
                {
                    <govuk-error-summary>
                        <govuk-error-summary-item href="#">@TempData["RemoveFertiliserError"]</govuk-error-summary-item>
                    </govuk-error-summary>
                }

                <h1 class="govuk-heading-l">
                    @if (!string.IsNullOrWhiteSpace(Model.FieldName))
                    {
                        @(string.Format(Resource.lblRemoveAnInorganicFertiliserApplicationFromField, Model.FieldName))
                    }
                    else
                    {
                        @Resource.lblRemoveAnInorganicFertiliserApplication
                    }

                </h1>

                <div class="govuk-body">
                    @if (!string.IsNullOrWhiteSpace(Model.FieldName))
                    {
                        @string.Format(Resource.MsgDeleteFertiliserContent1,Model.FieldName)
                    }
                    else
                    {
                        @string.Format(Resource.MsgDeleteFertiliserContent1, Resource.lblTheseFields)
                    }
                </div>
                @if (ViewBag.SelectedFields != null)
                {

                    <p class="govuk-body">
                        <ul class="govuk-body">
                            @foreach (var item in ViewBag.SelectedFields)
                            {
                                <li>@item</li>
                            }
                        </ul>
                        @*  @foreach (var item in ViewBag.SelectedFields)
                {
                @item <br />
                } *@
                    </p>
                }
                <govuk-radios class="govuk-radios--inline" for="@Model.IsDeleteFertliser">
                    <govuk-radios-fieldset>
                        <govuk-radios-fieldset-legend>
                            @Resource.lblAreYouSureYouWantToContinue
                        </govuk-radios-fieldset-legend>
                        <govuk-radios-item value="@yes">@Resource.lblYes</govuk-radios-item>
                        <govuk-radios-item value="@no">@Resource.lblNo</govuk-radios-item>
                    </govuk-radios-fieldset>
                </govuk-radios>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>
               @*  @if (Model.IsComingFromRecommendation)
                {
                    <p class="govuk-body cancel-link"><a asp-action="Recommendations" asp-controller="Crop" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@ViewBag.EncryptedFieldId" asp-route-s="@Model.EncryptedHarvestYear">@Resource.lblCancel</a></p>

                }
                else
                { *@
                    <p class="govuk-body cancel-link"><a asp-action="CheckAnswer" asp-controller="FertiliserManure">@Resource.lblCancel</a></p>

                @* } *@

            </div>
        </div>
    </form>


}
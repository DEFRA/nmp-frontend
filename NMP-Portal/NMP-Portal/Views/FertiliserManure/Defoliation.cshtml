@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.FertiliserManureViewModel
@{
    var heading = "";
    if (Model.IsSameDefoliationForAll.HasValue && Model.IsSameDefoliationForAll.Value && Model.GrassCropCount > 1)
    {
        heading = ((Model.GrassCropCount != null && Model.GrassCropCount == 1) ? string.Format(Resource.lblWhichCutOrGrazingInThisInorganicApplicationForInField, Model.FieldName) : Resource.lblWhichCutOrGrazingInThisInorganicApplicationForAllField);
    }
    else
    {
        heading = string.Format(Resource.lblWhichCutOrGrazingInThisInorganicApplicationForInField, Model.FieldName);
    }
    string title = (!string.IsNullOrEmpty(Model.EncryptedFertId)) ? Resource.lblUpdateInorganicFeriliser : Resource.lblAddInorganicFeriliser;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";
    string defoliation = string.Empty;
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.FertiliserWizardSteps.Defoliation;
}
@section BeforeContent {
    <govuk-back-link asp-action=@((Model.IsCheckAnswer && (!Model.IsAnyChangeInSameDefoliationFlag) && (!Model.IsAnyChangeInField) && (!Model.IsDoubleCropValueChange)) ? "CheckAnswer" : "Defoliation") asp-controller="FertiliserManure" asp-route-q="@Model.DefoliationEncryptedCounter">@Resource.lblBack</govuk-back-link>
}



<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <form asp-action="Defoliation" asp-controller="FertiliserManure" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
            @if (TempData["DefoliationError"] != null)
            {
                <govuk-error-summary>
                    <govuk-error-summary-item>@TempData["DefoliationError"]</govuk-error-summary-item>
                </govuk-error-summary>
            }
            @await Html.PartialAsync("~/Views/FertiliserManure/_FertiliserWizardHiddenFields.cshtml", Model)
            @if (Model.DefoliationList != null && Model.DefoliationList.Count > 0 && Model.FertiliserManures.Any(x => x.IsGrass))
            {
                @for (int i = 0; i < Model.DefoliationList.Count; i++)
                {                   
                    @if (Model.DefoliationCurrentCounter == i)
                    {
                        <govuk-radios for="@Model.DefoliationList[i].Defoliation">
                            <govuk-radios-fieldset>
                                <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                                    @if (Model.IsSameDefoliationForAll.HasValue && Model.IsSameDefoliationForAll.Value && Model.GrassCropCount > 1)
                                    {
                                        @((Model.GrassCropCount != null && Model.GrassCropCount == 1) ?
                                                                string.Format(Resource.lblWhichCutOrGrazingInThisInorganicApplicationForInField, Model.FieldName) :
                                                                Resource.lblWhichCutOrGrazingInThisInorganicApplicationForAllField)
                                                }
                                    else
                                    {
                                        @string.Format(Resource.lblWhichCutOrGrazingInThisInorganicApplicationForInField, Model.FieldName)
                                    }
                                </govuk-radios-fieldset-legend>
                                <govuk-radios-hint>@Resource.lblSelectOneOption</govuk-radios-hint>
                                @if (ViewBag.DefoliationList != null)
                                {
                                    @foreach (var item in ViewBag.DefoliationList)
                                    {
                                        <govuk-radios-item value="@item.Value">@item.Text</govuk-radios-item>
                                    }
                                }

                            </govuk-radios-fieldset>
                        </govuk-radios>
                    }
                        else
                        {
                        <input class="govuk-visually-hidden" type="hidden" asp-for="@Model.DefoliationList[i].Defoliation" />
                        }
                    }
            }

            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>
            <p class="govuk-body cancel-link">
                @if (!Model.IsCheckAnswer)
                {
                    <a asp-action="CreateManureCancel" asp-controller="OrganicManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="OrganicManure">@Resource.lblCancel</a>
                }
            </p>
        </form>
    </div>

</div>


@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.FertiliserManureViewModel
@{
    var heading = (string.IsNullOrWhiteSpace(Model.EncryptedFertId)) ? Resource.lblHowMuchOfEachNutrientDoYouPlan : Resource.lblHowMuchOfEachNutrientDoYouPlanforUpdate;

    string title = (!string.IsNullOrEmpty(Model.EncryptedFertId)) ? Resource.lblUpdateInorganicFeriliser : Resource.lblAddInorganicFeriliser;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {title}";
    var count = 0;

    var isFieldsEmpty = false;
    if (ViewData["IsPostRequest"] != null)
    {
        isFieldsEmpty = (Model.N == null && Model.P2O5 == null
                    && Model.K2O == null && Model.SO3 == null && Model.MgO == null
                    && Model.Lime == null);
    }
    int trueWarningCount = 0;
    if (Model.IsClosedPeriodWarning) trueWarningCount++;
    if (Model.IsNitrogenExceedWarning) trueWarningCount++;
    if (Model.IsNMaxLimitWarning) trueWarningCount++;
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.FertiliserWizardSteps.NutrientValue;
}

@section BeforeContent {
    <govuk-back-link asp-action=@((Model.IsCheckAnswer && (!Model.IsAnyChangeInField)) ? "CheckAnswer" : "InOrgnaicManureDuration") asp-controller="FertiliserManure" asp-route-q="@Model.EncryptedCounter">@Resource.lblBack</govuk-back-link>
}
<div class="govuk-grid-row">

    <form asp-action="NutrientValues" asp-controller="FertiliserManure" method="post" autocomplete="off">
        @Html.AntiForgeryToken()

        @if (TempData["NutrientValuesError"] != null)
        {
            <govuk-error-summary>
                <govuk-error-summary-item>@TempData["NutrientValuesError"]</govuk-error-summary-item>
            </govuk-error-summary>
        }

        @await Html.PartialAsync("~/Views/FertiliserManure/_FertiliserWizardHiddenFields.cshtml", Model)
        @if (isFieldsEmpty)
        {
            <govuk-error-summary>
                <govuk-error-summary-item href="#N">@Resource.MsgEnterAnAmountForAMinimumOfOneNutrientBeforeContinuing</govuk-error-summary-item>
            </govuk-error-summary>
        }
        <div class="govuk-form-group @(isFieldsEmpty ? "govuk-form-group--error" : "")">
            <div class="govuk-grid-column-two-thirds">
                @if (Model.IsWarningMsgNeedToShow && Model.N > 0)
                {
                    <govuk-notification-banner>
                        <govuk-notification-banner-title>
                            @Resource.lblImportant
                        </govuk-notification-banner-title>
                        @if (trueWarningCount == 1)
                        {
                            @if (Model.IsClosedPeriodWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodWarningPara1))
                            {
                                <p class="govuk-notification-banner__heading">
                                    @Model.ClosedPeriodWarningPara1
                                </p>
                                <p class="govuk-body">@Model.ClosedPeriodWarningPara3</p>
                            }

                            @if (Model.IsNitrogenExceedWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodNitrogenExceedWarningPara1))
                            {
                                <p class="govuk-notification-banner__heading">
                                    @Model.ClosedPeriodNitrogenExceedWarningPara1
                                </p>
                                <p class="govuk-body">@Model.ClosedPeriodNitrogenExceedWarningPara2</p>

                                @if (!string.IsNullOrWhiteSpace(Model.ClosedPeriodNitrogenExceedWarningPara3))
                                {
                                    <p class="govuk-body">@Model.ClosedPeriodNitrogenExceedWarningPara3</p>
                                }
                            }
                            @if (Model.IsNMaxLimitWarning && !string.IsNullOrWhiteSpace(Model.CropNmaxLimitWarningPara1))
                            {
                                <p class="govuk-notification-banner__heading">
                                    @Model.CropNmaxLimitWarningPara1
                                </p>
                                <p class="govuk-body warning-text">@Model.CropNmaxLimitWarningPara2</p>
                                @if (Model.CropNmaxLimitWarningPara3 != null)
                                {
                                    <p class="govuk-body">@Model.CropNmaxLimitWarningPara3</p>
                                }
                            }

                        }
                        @if (trueWarningCount > 1)
                        {
                            @* <div class="govuk-notification-banner__content">*@
                            <p class="govuk-notification-banner__heading">
                                @if (Model.FarmCountryId == (int)NMP.Commons.Enums.FarmCountry.England || Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland)
                                {
                                    @Resource.lblThisApplicationMayBreachMoreThanOneNVZRule
                                }
                                @if (Model.FarmCountryId == (int)NMP.Commons.Enums.FarmCountry.Wales)
                                {
                                    @Resource.lblThisApplicationMayBreachMoreThanOneWaterResourceRegulation
                                }
                            </p>
                            <ul class="govuk-list govuk-list--bullet">
                                @if (Model.IsClosedPeriodWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodWarningPara1))
                                {
                                    <li>@Model.ClosedPeriodWarningPara1</li>
                                }
                                @if (Model.IsNitrogenExceedWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodNitrogenExceedWarningPara1))
                                {
                                    <li>@Model.ClosedPeriodNitrogenExceedWarningPara1</li>
                                }
                                @if (Model.IsNMaxLimitWarning && !string.IsNullOrWhiteSpace(Model.CropNmaxLimitWarningPara1))
                                {
                                    <li>@Model.CropNmaxLimitWarningPara1</li>
                                }
                            </ul>
                            <govuk-details>
                                <govuk-details-summary>

                                    @if (Model.FarmCountryId == (int)NMP.Commons.Enums.FarmCountry.England || Model.FarmRB209CountryID == (int)NMP.Commons.Enums.RB209Country.Scotland)
                                    {
                                        @Resource.lblMoreAboutTheseNVZRules
                                    }
                                    @if (Model.FarmCountryId == (int)NMP.Commons.Enums.FarmCountry.Wales)
                                    {
                                        @Resource.lblMoreAboutTheseWaterResourceRegulation
                                    }
                                </govuk-details-summary>
                                <govuk-details-text>
                                    @if (Model.IsClosedPeriodWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodWarningPara1))
                                    {
                                        <h2 class="govuk-heading-s">@Model.ClosedPeriodWarningPara1</h2>
                                        <p class="govuk-body">@Model.ClosedPeriodWarningPara3</p>
                                    }
                                    @if (Model.IsNitrogenExceedWarning && !string.IsNullOrWhiteSpace(Model.ClosedPeriodNitrogenExceedWarningPara1))
                                    {
                                        <h2 class="govuk-heading-s">@Model.ClosedPeriodNitrogenExceedWarningPara1</h2>
                                        <p class="govuk-body">@Model.ClosedPeriodNitrogenExceedWarningPara2</p>
                                    }
                                    @if (Model.IsNMaxLimitWarning && !string.IsNullOrWhiteSpace(Model.CropNmaxLimitWarningPara1))
                                    {
                                        <h2 class="govuk-heading-s">@Model.CropNmaxLimitWarningPara1</h2>
                                        <p class="govuk-body warning-text">@Model.CropNmaxLimitWarningPara2</p>

                                    }
                                </govuk-details-text>
                            </govuk-details>
                            @if (Model.IsNMaxLimitWarning && !string.IsNullOrWhiteSpace(Model.CropNmaxLimitWarningPara1))
                            {
                                <p class="govuk-body">@Model.CropNmaxLimitWarningPara3</p>
                            }
                            else
                            {
                                <p class="govuk-body">@Model.ClosedPeriodNitrogenExceedWarningPara3</p>
                            }
                        }

                    </govuk-notification-banner>

                }
                <h1 class="govuk-heading-l">
                    @if (string.IsNullOrWhiteSpace(Model.EncryptedFertId))
                    {
                        @Resource.lblHowMuchOfEachNutrientDoYouPlan
                    }
                    else
                    {
                        @Resource.lblHowMuchOfEachNutrientDoYouPlanforUpdate
                    }
                </h1>
            </div>
            <div class="govuk-grid-column-full">
                @if (Model.FieldList?.Count == 1)
                {
                    if (Model.Recommendation != null)
                    {
                        <govuk-details>
                            <govuk-details-summary>
                                @string.Format(Resource.lblShowRecommendationsFor, Model.FieldName)
                            </govuk-details-summary>
                            <govuk-details-text class="table-container">
                                <h2 class="govuk-heading-m">
                                    @if (ViewBag.CropTypeId != null && ViewBag.CropTypeId == (int)NMP.Commons.Enums.CropTypes.Grass && ViewBag.DefoliationSequenceName != null)
                                    {                                        
                                        @string.Format(Resource.lblRecommendationsForGrass,
                                                        Model.FertiliserManures?.FirstOrDefault()?.Defoliation?.ToString() ?? string.Empty,
                                                        Html.Encode(ViewBag.DefoliationSequenceName as string ?? string.Empty)
                                                        )
                                    }
                                    else
                                    {
                                        @Resource.lblRecommendations
                                    }
                                </h2>
                                @{
                                    var recommendationData = new RecommendationData
                                    {
                                        Recommendation = Model.Recommendation,
                                        CropTypeID = ViewBag.CropTypeId
                                    };
                                }
                                @await Html.PartialAsync("~/Views/Crop/_RecommendationTabPartial.cshtml", recommendationData)

                            </govuk-details-text>
                        </govuk-details>
                    }
                }

            </div>
            <div class="govuk-grid-column-two-thirds">
                @if (isFieldsEmpty)
                {
                    <govuk-error-message for="@Model.N">
                        @Resource.MsgEnterAnAmountForAMinimumOfOneNutrientBeforeContinuing
                    </govuk-error-message>
                }
                <govuk-input for=@Model.N inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblNitrogen
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblOutpurKgPerHectare)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lblOutpurKgPerHectare</govuk-input-suffix>
                </govuk-input>
                <govuk-input for=@Model.P2O5 inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblPhosphateP2O5
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblOutpurKgPerHectare)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lblOutpurKgPerHectare</govuk-input-suffix>
                </govuk-input>
                <govuk-input for=@Model.K2O inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblPotashK2O
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblOutpurKgPerHectare)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lblOutpurKgPerHectare</govuk-input-suffix>
                </govuk-input>
                <govuk-input for=@Model.SO3 inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblSulphurSO3
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblOutpurKgPerHectare)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lblOutpurKgPerHectare</govuk-input-suffix>
                </govuk-input>
                <govuk-input for=@Model.MgO inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblMagnesiumMgO
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lblOutpurKgPerHectare)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lblOutpurKgPerHectare</govuk-input-suffix>
                </govuk-input>
                <govuk-input for=@Model.Lime inputmode="numeric" input-class="govuk-input--width-5" spellcheck="false">
                    <govuk-input-label is-page-heading="false">
                        @Resource.lblLime
                        <span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, Resource.lbltonnes)</span>
                    </govuk-input-label>
                    <govuk-input-suffix>@Resource.lbltonnes</govuk-input-suffix>
                </govuk-input>
            </div>
        </div>

        <div class="govuk-grid-column-two-thirds">
            <govuk-button type="submit" class="margin-bottom-forty">
                @Resource.lblContinue
            </govuk-button>

            <p class="govuk-body cancel-link">
                @if (string.IsNullOrWhiteSpace(Model.EncryptedFertId) && (!Model.IsCheckAnswer))
                {
                    <a asp-action="CreateFertiliserManureCancel" asp-controller="FertiliserManure" asp-route-q="@Model.EncryptedFarmId" asp-route-r="@Model.EncryptedHarvestYear">@Resource.lblCancel</a>
                }
                else
                {
                    <a asp-action="CheckAnswer" asp-controller="FertiliserManure">@Resource.lblCancel</a>
                }
            </p>
        </div>

    </form>

</div>
@{
    var logoutEndpoint = ViewData["LogoutEndpoint"] as string;
    var idToken = ViewData["IdToken"] as string;
    var postLogoutRedirectUri = ViewData["PostLogoutRedirectUri"] as string;
}
<!DOCTYPE html>
<html lang="en">
    <head>
    <title>Signing out...</title>
    </head>
<body onload='document.forms[0].submit()'>
    <form method='post' action='@logoutEndpoint'>
        <input type='hidden' name='id_token_hint' value='@idToken' />
        <input type='hidden' name='post_logout_redirect_uri' value='@postLogoutRedirectUri' />
    </form>
</body>
</html>

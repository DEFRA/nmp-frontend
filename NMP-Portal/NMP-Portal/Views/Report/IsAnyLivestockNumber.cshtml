@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.ReportViewModel
@{
    string title = string.Format(Resource.lblDidYouHaveAnyLivestockOn, Model.FarmName, Model.Year);
    ViewData["Title"] = $"{title} {Resource.lblHyphen} {Resource.lblAddLivestockNumber}";
    var yes = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.True);
    var no = Convert.ToBoolean((int)NMP.Commons.Enums.TrueFalse.False);
    var action = "";
    if (Model.IsLivestockCheckAnswer)
    {
        action = "LivestockCheckAnswer";
    }
    else
    {
        if (ViewBag.LiveStockList != null && ViewBag.LiveStockList.Count > 0)
        {
            action = "ManageLivestock";
        }
        else
        {
            action = "LivestockManureNitrogenReportChecklist";
        }
    }
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.ReportWizardSteps.IsAnyLivestockNumber;
}

@section BeforeContent {
    <govuk-back-link asp-action="@action" asp-controller="Report" asp-route-q="@Model.EncryptedFarmId" asp-route-y="@Model.EncryptedHarvestYear">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnIsAnyLivestockNumber"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["ErrorOnIsAnyLivestockNumber"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@if (Model != null)
{
    <form asp-action="IsAnyLivestockNumber" asp-controller="Report" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/Report/_ReportWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <govuk-radios class="govuk-radios--inline" asp-for="@Model.IsAnyLivestockNumber">
                    <govuk-radios-fieldset>
                        <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                            @title
                        </govuk-radios-fieldset-legend>
                        <govuk-radios-hint>@Resource.lblIncludeCattleSheepPigsPoultryGoats <br /> <br /> @Resource.lblSelectOneOption</govuk-radios-hint>
                        <govuk-radios-item value=@yes>@Resource.lblYes</govuk-radios-item>
                        <govuk-radios-item value="@no">@Resource.lblNo</govuk-radios-item>
                    </govuk-radios-fieldset>
                </govuk-radios>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>
                <p class="govuk-body cancel-link">
                    @if (!Model.IsManageLivestock || (Model.IsManageLivestock && Model.IsLivestockCheckAnswer))
                    {
                        @if (!Model.IsLivestockCheckAnswer)
                        {
                            <a asp-action="LivestockManureNitrogenReportChecklist" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                        else
                        {
                            <a asp-action="LivestockCheckAnswer" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-action="ManageLivestock" asp-controller="Report" asp-route-q="@Model.EncryptedFarmId" asp-route-y="@Model.EncryptedHarvestYear">
                            @Resource.lblCancel
                        </a>
                    }
                </p>
            </div>
        </div>
    </form>
}
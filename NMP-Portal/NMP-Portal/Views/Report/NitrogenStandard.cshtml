@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.ReportViewModel
@{
    ViewData["Title"] = $"{string.Format(Resource.lblWhatIsTheNitrogenNStandardForThisLivestock, Model.Year)} {Resource.lblHyphen} {Resource.lblAddLivestockNumber}";
    var backAction = "";
    if (Model.IsLivestockCheckAnswer && !Model.IsLivestockGroupChange)
    {
        backAction = "LivestockCheckAnswer";
    }
    else
    {
        if (Model.OccupancyAndNitrogenOptions == (int)NMP.Commons.Enums.OccupancyNitrogenOptions.DerogatedFarmChangeBoth)
        {
            backAction = "Occupancy";
        }
        else
        {
            backAction = "OccupancyAndStandard";
        }
    }

    ViewBag.CurrentStep = (int)NMP.Commons.Enums.ReportWizardSteps.NitrogenStandard;
}

@section BeforeContent {
    <govuk-back-link asp-action="@backAction" asp-controller="Report">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnNitrogenStandard"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["ErrorOnNitrogenStandard"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@if (Model != null)
{
    <form asp-action="NitrogenStandard" asp-controller="Report" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/Report/_ReportWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <govuk-fieldset>
                    <govuk-fieldset-legend class="govuk-fieldset__legend--l">
                        @string.Format(Resource.lblNitrogenNStandardForThistype, Model.LivestockGroupName.ToLower())
                    </govuk-fieldset-legend>
                    <p class="govuk-body">@string.Format(Resource.lblSelectedLivestockType, Model.LivestockTypeName)</p>
                    <govuk-details>
                        <govuk-details-summary>
                            @Resource.lblHelpWithNitrogenNStandard
                        </govuk-details-summary>
                        <govuk-details-text class="explanations">
                            <p class="govuk-body">
                                @Resource.lblTheNitrogenStandardFigureIsTheAverageNitrogenProduced
                            </p>
                            <p class="govuk-body margin-bottom-forty">
                                @Resource.lblThisFigureAccountsForOccupancyAlready
                            </p>
                        </govuk-details-text>
                    </govuk-details>
                    <govuk-input asp-for=@Model.NitrogenStandard type="number" step="any" spellcheck="false">
                        <govuk-input-label is-page-heading="false">
                            @string.Format(Resource.lblWhatIsTheNitrogenNStandardForThis, Model.LivestockGroupName.ToLower(), Model.Year)<span class="govuk-visually-hidden"> @string.Format(Resource.lblInUnit, ((Model.LivestockGroupId == (int)NMP.Commons.Enums.LivestockGroup.Pigs || Model.LivestockTypeId == (int)NMP.Commons.Enums.Livestock.OneOstrich) ? Resource.lblKgOfNitrogenNPerPlace : Resource.lblKgOfNitrogenNPer1000Places))</span>@Resource.lblQuestionMark
                        </govuk-input-label>
                        <govuk-input-hint>
                            @(string.Format(Resource.lblThisValueIsFromTheNVZRegulationAndTakesIntoAccount, Model.Country == (int)NMP.Commons.Enums.FarmCountry.Wales ? Resource.lblWaterResourcesRegulations : Resource.lblNVZRegulation))
                        </govuk-input-hint>
                        <govuk-input-suffix>@((Model.LivestockGroupId == (int)NMP.Commons.Enums.LivestockGroup.Pigs || Model.LivestockTypeId == (int)NMP.Commons.Enums.Livestock.OneOstrich) ? Resource.lblKgOfNitrogenNPerPlace : Resource.lblKgOfNitrogenNPer1000Places)</govuk-input-suffix>
                    </govuk-input>
                </govuk-fieldset>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>

                <p class="govuk-body cancel-link">
                    @if (!Model.IsManageLivestock || (Model.IsManageLivestock && Model.IsLivestockCheckAnswer))
                    {
                        @if (!Model.IsLivestockCheckAnswer)
                        {
                            <a asp-action="LivestockManureNitrogenReportChecklist" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                        else
                        {
                            <a asp-action="LivestockCheckAnswer" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-action="ManageLivestock" asp-controller="Report" asp-route-q="@Model.EncryptedFarmId" asp-route-y="@Model.EncryptedHarvestYear">
                            @Resource.lblCancel
                        </a>
                    }
                </p>

            </div>

        </div>
    </form>
}
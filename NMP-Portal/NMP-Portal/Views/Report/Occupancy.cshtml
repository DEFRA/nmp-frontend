@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.ReportViewModel
@{
    ViewData["Title"] = $"{string.Format(Resource.lblWhatIsTheOccupancyForThisLivestockTypeIn, Model.Year)}  {Resource.lblHyphen} {Resource.lblAddLivestockNumber}";

    ViewBag.CurrentStep = (int)NMP.Commons.Enums.ReportWizardSteps.Occupancy;
}

@section BeforeContent {
    <govuk-back-link asp-action="@((Model.IsLivestockCheckAnswer && !Model.IsLivestockGroupChange) ? "LivestockCheckAnswer" : "OccupancyAndStandard")" asp-controller="Report">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnOccupancy"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["ErrorOnOccupancy"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@if (Model != null)
{
    <form asp-action="Occupancy" asp-controller="Report" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/Report/_ReportWizardHiddenFields.cshtml", Model)
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <govuk-fieldset>
                    <govuk-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                        @string.Format(Resource.lblOccupancyForThistype, Model.LivestockGroupName.ToLower())
                    </govuk-fieldset-legend>
                    <p class="govuk-body">@string.Format(Resource.lblSelectedLivestockType, Model.LivestockTypeName)</p>
                    <govuk-details>
                        <govuk-details-summary>
                            @Resource.lblHelpWithOccupancy
                        </govuk-details-summary>
                        <govuk-details-text class="explanations">
                            <p class="govuk-body">
                                @Resource.lblTheseAnimalsAreCountedByTheNumberOfPlacesForThem
                            </p>
                            <p class="govuk-body">
                                @Resource.lblIfTheOccupancyOnYourFarmIsDifferentToTheValueShownHere
                            </p>
                        </govuk-details-text>
                    </govuk-details>
                    <govuk-input asp-for=@Model.AverageOccupancy type="number" step="any" spellcheck="false">
                        <govuk-input-label is-page-heading="false">
                            @string.Format(Resource.lblWhatIsTheOccupancyForThis, Model.LivestockGroupName.ToLower(), Model.Year)<span class="govuk-visually-hidden">@string.Format(Resource.lblInUnit, Resource.lblPercentage)</span>@Resource.lblQuestionMark
                        </govuk-input-label>
                        <govuk-input-suffix>@Resource.lblPercentage</govuk-input-suffix>
                    </govuk-input>
                </govuk-fieldset>
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>

                <p class="govuk-body cancel-link">
                    @if (!Model.IsManageLivestock || (Model.IsManageLivestock && Model.IsLivestockCheckAnswer))
                    {
                        @if (!Model.IsLivestockCheckAnswer)
                        {
                            <a asp-action="LivestockManureNitrogenReportChecklist" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                        else
                        {
                            <a asp-action="LivestockCheckAnswer" asp-controller="Report">
                                @Resource.lblCancel
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-action="ManageLivestock" asp-controller="Report" asp-route-q="@Model.EncryptedFarmId" asp-route-y="@Model.EncryptedHarvestYear">
                            @Resource.lblCancel
                        </a>
                    }
                </p>

            </div>

        </div>
    </form>
}
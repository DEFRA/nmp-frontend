@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.ReportViewModel
@{
    var heading = "";
    if (Model.FieldAndPlanReportOption == (int)NMP.Commons.Enums.FieldAndPlanReportOption.CropFieldManagementReport ||
                                        Model.NVZReportOption == (int)NMP.Commons.Enums.NvzReportOption.NmaxReport)
    {
        heading = string.Format(Resource.lblForYearForReport, Model.ReportTypeName);
    }
    if (Model.NVZReportOption == (int)NMP.Commons.Enums.NvzReportOption.LivestockManureNFarmLimitReport)
    {
        heading = Model.Country == (int)NMP.Commons.Enums.FarmCountry.Wales ?Resource.lblWhichYearWouldYouLikeToCreateAHoldingNitrogenLimit :Resource.lblWhichYearWouldYouLikeToCreateALivestockReport;
    }
    if (Model.NVZReportOption == (int)NMP.Commons.Enums.NvzReportOption.ExistingManureStorageCapacityReport)
    {
        heading = Resource.lblWhichYearWouldYouLikeToCreateExistingManureReport;
    }
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {Resource.lblReport}";

    var currentYear = DateTime.Now.Year;
    var nextYear = DateTime.Now.Year + 1;
    var backAction = (Model.ReportOption == (int)NMP.Commons.Enums.ReportOption.FieldRecordsAndPlan)
        ? "ReportOptions" : "NVZComplianceReports";
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.ReportWizardSteps.Year;
}

@section BeforeContent {
    <govuk-back-link asp-action="@backAction" asp-controller="Report">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnYear"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#Year">@TempData["ErrorOnYear"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}

@if (TempData["succesMsgContent1"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <div class="margin-bottom-thirty">
                <govuk-notification-banner type="NotificationBannerType.Success">
                    <p class="govuk-notification-banner__heading">
                        @TempData["succesMsgContent1"]
                    </p>
                </govuk-notification-banner>
            </div>
        </div>
    </div>
}

@if (Model != null)
{
    <form asp-action="Year" asp-controller="Report" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/Report/_ReportWizardHiddenFields.cshtml", Model)
        
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds-from-desktop">
                    <govuk-radios asp-for="@Model.Year">
                        <govuk-radios-fieldset>
                            <govuk-radios-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
                                @heading
                            </govuk-radios-fieldset-legend>
                            <govuk-radios-hint>
                                @Resource.lblSelectOneOption
                            </govuk-radios-hint>
                            @if (ViewBag.Years != null)
                            {
                                foreach (int year in ViewBag.Years)
                                {
                                    <govuk-radios-item value="@year">
                                        @year
                                    </govuk-radios-item>
                                }
                            }
                        </govuk-radios-fieldset>
                    </govuk-radios>                
                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>
                <p class="govuk-body cancel-link">
                    <a asp-action="FarmSummary" asp-controller="Farm" asp-route-Id="@Model.EncryptedFarmId">
                        @Resource.lblCancel
                    </a>
                </p>
            </div>
        </div>
    </form>
}
@using NMP.Commons.Resources
@model NMP.Commons.ViewModels.ReportViewModel
@{
    string heading = (Model.ImportExport.Value == (int)NMP.Commons.Enums.ImportExport.Import ?
                                        Resource.lblWhoAreYouImportingThisLivestockManureFrom :
                                        Resource.lblWhoAreYouExportingThisLivestockManureTo);
    string action = string.IsNullOrWhiteSpace(Model.EncryptedId) ? Char.ToUpper(Resource.lblAdd[0]) + Resource.lblAdd.Substring(1) : Resource.lblUpdate;
    ViewData["Title"] = $"{heading} {Resource.lblHyphen} {action} {Resource.lblImportsExportsOfLivestockManure}";
    var suffixUnit = "";
    if (Model.IsManureTypeLiquid != null)
    {
        suffixUnit = Model.IsManureTypeLiquid.Value ? Resource.lblKgPerMeterCube : Resource.lblKgPerTonne;
    }
    ViewBag.CurrentStep = (int)NMP.Commons.Enums.ReportWizardSteps.LivestockReceiver;
}

@section BeforeContent {
    <govuk-back-link asp-action=@(Model.IsCheckAnswer ?
                                      "LivestockImportExportCheckAnswer" :
                                      (!string.IsNullOrWhiteSpace(Model.DefaultNutrientValue) && (Model.DefaultNutrientValue == Resource.lblIwantToEnterARecentOrganicMaterialAnalysis) ?
                                      "LivestockManualNutrientValue" : "LivestockDefaultNutrientValue")) asp-controller="Report">@Resource.lblBack</govuk-back-link>
}
@if (TempData["ErrorOnLivestockReceiver"] != null)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-error-summary>
                <govuk-error-summary-item href="#">@TempData["ErrorOnLivestockReceiver"]</govuk-error-summary-item>
            </govuk-error-summary>
        </div>
    </div>
}
@if (Model != null)
{
    <form asp-action="LivestockReceiver" asp-controller="Report" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("~/Views/Report/_ReportWizardHiddenFields.cshtml", Model)
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <govuk-fieldset>
                <govuk-fieldset-legend class="govuk-fieldset__legend--l">
                    @(Model.ImportExport.Value == (int)NMP.Commons.Enums.ImportExport.Import ?
                                        Resource.lblWhoAreYouImportingThisLivestockManureFrom :
                                        Resource.lblWhoAreYouExportingThisLivestockManureTo)
                </govuk-fieldset-legend>
                    <govuk-input asp-for="@Model.ReceiverName">
                        <govuk-input-label>@Resource.lblName</govuk-input-label>
                    </govuk-input>
                    <govuk-input asp-for="@Model.Address1" id="Address1">
                        <govuk-input-label>@string.Format("{0} {1}", Resource.lblAddressLine1, Resource.lblOptional)</govuk-input-label>
                    </govuk-input>
                    <govuk-input asp-for="@Model.Address2">
                        <govuk-input-label>@Resource.lblAddressLine2</govuk-input-label>
                    </govuk-input>
                    <govuk-input class="govuk-input--width-20" asp-for="@Model.Address3">
                        <govuk-input-label>@string.Format("{0} {1}", Resource.lblTownOrCity, Resource.lblOptional)</govuk-input-label>
                    </govuk-input>
                    <govuk-input class="govuk-input--width-20" asp-for="@Model.Address4">
                        <govuk-input-label>@string.Format("{0} {1}", Resource.lblCounty, Resource.lblOptional)</govuk-input-label>
                    </govuk-input>
                    <govuk-input class="govuk-input--width-10" asp-for="@Model.Postcode">
                        <govuk-input-label>@string.Format("{0} {1}", Resource.lblPostCode, Resource.lblOptional)</govuk-input-label>
                    </govuk-input>
                </govuk-fieldset>

                <govuk-button type="submit" class="margin-bottom-forty">
                    @Resource.lblContinue
                </govuk-button>
                 @*  <p class="govuk-body cancel-link">
                    @if (!Model.IsCheckList)
                    {
                        <a asp-action="FarmSummary" asp-controller="Farm" asp-route-Id="@Model.EncryptedFarmId">
                            @Resource.lblCancel
                        </a>
                    }
                    else
                    {
                        <a asp-action="LivestockManureNitrogenReportChecklist" asp-controller="Report">
                            @Resource.lblCancel
                        </a>
                    }
                </p> *@

            </div>

     </div>
    </form>
}